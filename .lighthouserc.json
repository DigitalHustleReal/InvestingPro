{
  "ci": {
    "collect": {
      "url": [
        "http://localhost:3000",
        "http://localhost:3000/admin",
        "http://localhost:3000/admin/articles",
        "http://localhost:3000/loans",
        "http://localhost:3000/credit-cards",
        "http://localhost:3000/calculators/sip"
      ],
      "numberOfRuns": 3,
      "settings": {
        "onlyCategories": ["accessibility"],
        "chromeFlags": "--headless"
      }
    },
    "assert": {
      "preset": "lighthouse:no-pwa",
      "assertions": {
        "categories:accessibility": ["error", {"minScore": 0.95}],
        "color-contrast": "off",
        "heading-order": "warn",
        "html-has-lang": "error",
        "image-alt": "error",
        "label": "error",
        "link-name": "error",
        "button-name": "error"
      }
    },
    "upload": {
      "target": "temporary-public-storage",
      "reportFilenamePattern": "%%PATHNAME%%-%%DATETIME%%.report.%%EXTENSION%%"
    }
  }
}
