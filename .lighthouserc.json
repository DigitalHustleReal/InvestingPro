{
  "ci": {
    "collect": {
      "url": [
        "http://localhost:3000",
        "http://localhost:3000/loans",
        "http://localhost:3000/credit-cards",
        "http://localhost:3000/calculators/sip",
        "http://localhost:3000/calculators/emi"
      ],
      "numberOfRuns": 3,
      "settings": {
        "onlyCategories": ["accessibility", "performance", "seo", "best-practices"],
        "chromeFlags": "--headless --no-sandbox"
      }
    },
    "assert": {
      "preset": "lighthouse:no-pwa",
      "assertions": {
        "categories:accessibility": ["error", {"minScore": 0.90}],
        "categories:seo": ["warn", {"minScore": 0.85}],
        "categories:performance": ["warn", {"minScore": 0.70}],
        "categories:best-practices": ["warn", {"minScore": 0.85}],
        "color-contrast": "off",
        "heading-order": "warn",
        "html-has-lang": "error",
        "image-alt": "error",
        "label": "error",
        "link-name": "error",
        "button-name": "error",
        "meta-description": "error",
        "document-title": "error",
        "canonical": "warn",
        "robots-txt": "warn"
      }
    },
    "upload": {
      "target": "temporary-public-storage",
      "reportFilenamePattern": "%%PATHNAME%%-%%DATETIME%%.report.%%EXTENSION%%"
    }
  }
}
