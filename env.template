# InvestingPro.in Environment Variables
# Copy this file to .env.local and fill in your values

# ===========================================
# DATABASE (Required)
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ===========================================
# AI PROVIDERS (At least one required)
# ===========================================
GROQ_API_KEY=your_groq_api_key
MISTRAL_API_KEY=your_mistral_api_key
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
GOOGLE_GEMINI_API_KEY=your_gemini_api_key

# ===========================================
# AUTHENTICATION (Development Only)
# ===========================================
# Set this for local development to bypass admin auth
# NEVER set this in production!
# ADMIN_BYPASS_KEY=your_secret_dev_key

# ===========================================
# SENTRY - Error Monitoring (Free)
# https://sentry.io
# ===========================================
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn

# ===========================================
# RESEND - Transactional Email (Free tier: 100/day)
# https://resend.com
# ===========================================
RESEND_API_KEY=your_resend_api_key

# ===========================================
# UPSTASH REDIS - Caching (Free tier: 10k commands/day)
# https://upstash.com
# ===========================================
UPSTASH_REDIS_REST_URL=your_upstash_redis_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# ===========================================
# POSTHOG - Product Analytics (Free tier: 1M events/month)
# https://posthog.com
# ===========================================
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_project_api_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ===========================================
# STRIPE - Payments (Pay per transaction)
# https://stripe.com
# ===========================================
STRIPE_SECRET_KEY=sk_live_or_test_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRO_MONTHLY_PRICE_ID=price_xxx
STRIPE_PRO_ANNUAL_PRICE_ID=price_xxx

# ===========================================
# EXTERNAL APIS (Optional)
# ===========================================
SERPAPI_KEY=your_serpapi_key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
PEXELS_API_KEY=your_pexels_api_key

# ===========================================
# APPLICATION CONFIG
# ===========================================
NEXT_PUBLIC_BASE_URL=https://investingpro.in
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NODE_ENV=development
