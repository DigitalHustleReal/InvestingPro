}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:system-ui,sans-serif;font-size:13px;background:#F5F0E8;color:#1B2A4A;padding:20px 24px;max-width:1100px;margin:0 auto}
h1{font-family:Georgia,serif;font-size:22px;font-style:italic;margin-bottom:18px;color:#1B2A4A}
h1 em{color:#E8871A}
.grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:16px}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px}
.card{border-radius:var(--border-radius-lg);border:0.5px solid var(--color-border-tertiary);background:var(--color-background-primary);overflow:hidden}
.card-hd{padding:10px 14px;border-bottom:0.5px solid var(--color-border-tertiary);display:flex;align-items:center;gap:8px}
.card-hd h3{font-size:13px;font-weight:500;color:var(--color-text-primary)}
.dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.card-body{padding:12px 14px;display:flex;flex-direction:column;gap:5px}
.item{display:flex;align-items:flex-start;gap:7px;padding:4px 0;border-bottom:0.5px solid var(--color-border-tertiary);font-size:12px;color:var(--color-text-secondary)}
.item:last-child{border:none}
.item-name{color:var(--color-text-primary);font-weight:500;min-width:120px;flex-shrink:0}
.item-detail{color:var(--color-text-secondary);line-height:1.4}
.tag{display:inline-block;padding:1px 7px;border-radius:10px;font-size:10px;font-weight:500;margin-left:auto;flex-shrink:0;white-space:nowrap}
.warn-box{border-radius:var(--border-radius-lg);border:0.5px solid var(--color-border-warning);background:var(--color-background-warning);padding:12px 16px;margin-bottom:16px}
.warn-title{font-size:11px;font-weight:500;color:var(--color-text-warning);margin-bottom:6px}
.warn-body{font-size:12px;color:var(--color-text-warning);line-height:1.6}
.phase-row{display:flex;gap:0;margin-bottom:16px;border-radius:var(--border-radius-lg);overflow:hidden;border:0.5px solid var(--color-border-tertiary)}
.phase{flex:1;padding:12px 14px;border-right:0.5px solid var(--color-border-tertiary);background:var(--color-background-primary)}
.phase:last-child{border:none}
.phase-label{font-size:9px;letter-spacing:.1em;text-transform:uppercase;font-weight:600;margin-bottom:5px}
.phase-title{font-size:13px;font-weight:500;color:var(--color-text-primary);margin-bottom:4px}
.phase-items{font-size:11px;color:var(--color-text-secondary);line-height:1.65}
.revenue-row{display:flex;gap:0;border:0.5px solid var(--color-border-tertiary);border-radius:var(--border-radius-lg);overflow:hidden;margin-bottom:16px;background:var(--color-background-primary)}
.rev-col{flex:1;padding:12px 14px;border-right:0.5px solid var(--color-border-tertiary);text-align:center}
.rev-col:last-child{border:none}
.rev-n{font-size:22px;font-weight:500;color:var(--color-text-primary);margin-bottom:2px}
.rev-l{font-size:11px;color:var(--color-text-secondary)}
.sec-title{font-size:16px;font-weight:500;color:var(--color-text-primary);margin-bottom:10px;padding-top:4px}
@media(max-width:700px){
  .grid{grid-template-columns:1fr 1fr}
  .phase-row{flex-direction:column}
  .phase{border-right:none;border-bottom:0.5px solid var(--color-border-tertiary)}
  .revenue-row{flex-wrap:wrap}
  .rev-col{min-width:33%}
}
@media(max-width:480px){
  .grid,.grid2{grid-template-columns:1fr}
  body{padding:14px 14px}
}
</style>
</head>
