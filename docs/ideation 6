<script>
function show(id, el){
  document.querySelectorAll('.doc-section').forEach(s=>s.classList.remove('active'));
  document.querySelectorAll('.dn-item').forEach(i=>i.classList.remove('active'));
  document.getElementById('s-'+id).classList.add('active');
  el.classList.add('active');
  window.scrollTo(0,0);
}
// SmartAdvisor chip interaction
document.querySelectorAll('.sb-chip').forEach(c=>{
  c.addEventListener('click',function(){
    this.classList.toggle('picked');
  });
});
// Filter bar interaction
document.querySelectorAll('.fb-chip').forEach(c=>{
  c.addEventListener('click',function(){
    document.querySelectorAll('.fb-chip').forEach(x=>x.classList.remove('active'));
    this.classList.add('active');
  });
});
</script>
