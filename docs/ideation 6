<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>InvestingPro — Design Language & Product Vision</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,500;0,9..144,700;1,9..144,300;1,9..144,500&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════════════
   DESIGN DOCUMENT CHROME
═══════════════════════════════════════════════ */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;background:#F5F0E8;color:#1B2A4A;font-size:13px;line-height:1.5}

/* ── DOC SIDEBAR ── */
#doc-nav{position:fixed;left:0;top:0;bottom:0;width:200px;background:#1B2A4A;z-index:200;overflow-y:auto;scrollbar-width:none}
#doc-nav::-webkit-scrollbar{display:none}
.dn-logo{padding:24px 20px 16px;border-bottom:1px solid rgba(255,255,255,.08)}
.dn-brand{font-family:'Fraunces',serif;font-size:18px;font-weight:500;color:#F5F0E8;font-style:italic}
.dn-tag{font-family:'DM Mono',monospace;font-size:8px;letter-spacing:.15em;text-transform:uppercase;color:rgba(245,240,232,.35);margin-top:3px}
.dn-sec{padding:18px 16px 6px;font-family:'DM Mono',monospace;font-size:8px;letter-spacing:.14em;text-transform:uppercase;color:rgba(245,240,232,.3)}
.dn-item{display:flex;align-items:center;gap:8px;padding:8px 16px;cursor:pointer;font-size:12px;color:rgba(245,240,232,.55);transition:all .15s;border-left:2px solid transparent}
.dn-item:hover{color:#F5F0E8;background:rgba(255,255,255,.04)}
.dn-item.active{color:#E8871A;border-left-color:#E8871A;background:rgba(232,135,26,.06)}
.dn-item .ico{font-size:13px;width:16px;text-align:center;flex-shrink:0}
.dn-footer{padding:16px;border-top:1px solid rgba(255,255,255,.08);margin-top:auto}
.dn-footer p{font-family:'DM Mono',monospace;font-size:8px;color:rgba(245,240,232,.25);line-height:1.6}

#doc-body{margin-left:200px}
.doc-section{display:none;min-height:100vh}
.doc-section.active{display:block}

/* ═══════════════════════════════════════════════
   INVESTINGPRO DESIGN TOKENS
═══════════════════════════════════════════════ */
:root{
  /* Brand Palette */
  --ink:#1B2A4A;        /* Deep Navy — primary text, authority */
  --saffron:#E8871A;    /* Saffron — Indian accent, CTA, energy */
  --forest:#1A6B4A;     /* Forest Green — positive, approve, grow */
  --cream:#F5F0E8;      /* Warm Cream — background, Indian warmth */
  --paper:#FFFDF8;      /* Paper White — card backgrounds */
  --mist:#EDE8DF;       /* Mist — borders, subtle dividers */
  --ash:#8A96A8;        /* Ash — secondary text */
  --fog:#B8C0CC;        /* Fog — placeholder, disabled */
  --red:#C0392B;        /* Error, decline */
  --gold:#D4A017;       /* Gold — premium, upgrade */
  --sky:#1E6FBF;        /* Sky Blue — informational links */
  /* Shadows */
  --s1:0 1px 3px rgba(27,42,74,.08);
  --s2:0 4px 16px rgba(27,42,74,.1);
  --s3:0 12px 40px rgba(27,42,74,.14);
  /* Spacing */
  --r4:4px;--r8:8px;--r12:12px;--r16:16px;--r24:24px;
}

/* ═══════════════════════════════════════════════
   SECTION: OVERVIEW
═══════════════════════════════════════════════ */
.overview-hero{background:var(--ink);min-height:100vh;display:flex;flex-direction:column;justify-content:center;padding:80px;position:relative;overflow:hidden}
.oh-texture{position:absolute;inset:0;background-image:url("data:image/svg+xml,%3Csvg width='60' height='60' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M54 54 L6 6' stroke='rgba(245,240,232,0.03)' stroke-width='0.5'/%3E%3C/svg%3E");pointer-events:none}
.oh-ring{position:absolute;right:-200px;top:-200px;width:700px;height:700px;border:1px solid rgba(232,135,26,.08);border-radius:50%}
.oh-ring2{position:absolute;right:-100px;top:-100px;width:500px;height:500px;border:1px solid rgba(232,135,26,.05);border-radius:50%}
.oh-tag{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--saffron);margin-bottom:20px;opacity:.8}
.oh-h1{font-family:'Fraunces',serif;font-size:clamp(42px,6vw,72px);font-weight:300;color:var(--cream);line-height:1.04;margin-bottom:16px}
.oh-h1 em{color:var(--saffron);font-style:italic}
.oh-sub{font-size:16px;color:rgba(245,240,232,.55);max-width:560px;line-height:1.7;margin-bottom:48px}
.oh-pills{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:60px}
.oh-pill{padding:6px 16px;border:1px solid rgba(245,240,232,.15);border-radius:20px;font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.08em;color:rgba(245,240,232,.5)}
.oh-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:rgba(245,240,232,.06);border-radius:var(--r12);overflow:hidden;max-width:720px}
.oh-stat{background:rgba(245,240,232,.03);padding:24px 28px}
.oh-stat .n{font-family:'Fraunces',serif;font-size:36px;font-weight:300;color:var(--cream)}
.oh-stat .l{font-family:'DM Mono',monospace;font-size:9px;letter-spacing:.1em;text-transform:uppercase;color:rgba(245,240,232,.35);margin-top:4px}
.doc-scroll-hint{position:absolute;bottom:40px;left:80px;display:flex;align-items:center;gap:8px;font-family:'DM Mono',monospace;font-size:9px;letter-spacing:.12em;text-transform:uppercase;color:rgba(245,240,232,.25)}

/* Philosophy block */
.philosophy{padding:80px;background:var(--paper)}
.phil-label{font-family:'DM Mono',monospace;font-size:9.5px;letter-spacing:.16em;text-transform:uppercase;color:var(--saffron);margin-bottom:20px}
.phil-h{font-family:'Fraunces',serif;font-size:clamp(28px,4vw,44px);font-weight:300;line-height:1.15;margin-bottom:30px;max-width:680px}
.phil-h em{font-style:italic;color:var(--saffron)}
.phil-cols{display:grid;grid-template-columns:1fr 1fr 1fr;gap:40px;margin-top:48px}
.phil-col h3{font-family:'Fraunces',serif;font-size:20px;font-weight:300;margin-bottom:10px;color:var(--ink)}
.phil-col p{font-size:13px;color:var(--ash);line-height:1.7}
.phil-col .num{font-family:'DM Mono',monospace;font-size:48px;font-weight:300;color:var(--mist);line-height:1;margin-bottom:16px}

/* ═══════════════════════════════════════════════
   SECTION: DESIGN SYSTEM
═══════════════════════════════════════════════ */
.ds-wrap{padding:64px 80px;background:var(--cream)}
.ds-title{font-family:'Fraunces',serif;font-size:36px;font-weight:300;margin-bottom:6px}
.ds-title em{font-style:italic;color:var(--saffron)}
.ds-sub{font-size:13px;color:var(--ash);margin-bottom:48px}

/* Colors */
.color-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:12px;margin-bottom:48px}
.color-chip{border-radius:var(--r12);overflow:hidden;box-shadow:var(--s1)}
.chip-swatch{height:80px}
.chip-info{background:var(--paper);padding:10px 12px}
.chip-name{font-size:11.5px;font-weight:600;color:var(--ink)}
.chip-hex{font-family:'DM Mono',monospace;font-size:10px;color:var(--ash);margin-top:1px}
.chip-role{font-size:10px;color:var(--fog);margin-top:2px}

/* Typography */
.type-showcase{background:var(--paper);border-radius:var(--r16);padding:48px;margin-bottom:32px;box-shadow:var(--s1)}
.type-row{display:flex;align-items:baseline;gap:20px;padding:20px 0;border-bottom:1px solid var(--mist)}
.type-row:last-child{border:none}
.type-meta{flex-shrink:0;width:180px}
.type-meta .name{font-family:'DM Mono',monospace;font-size:9px;letter-spacing:.1em;text-transform:uppercase;color:var(--ash)}
.type-meta .spec{font-family:'DM Mono',monospace;font-size:9px;color:var(--fog);margin-top:3px}
.type-sample{flex:1}

/* Components */
.comp-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-bottom:32px}
.comp-card{background:var(--paper);border-radius:var(--r16);padding:32px;box-shadow:var(--s1)}
.comp-label{font-family:'DM Mono',monospace;font-size:9px;letter-spacing:.12em;text-transform:uppercase;color:var(--ash);margin-bottom:20px}

/* Buttons */
.btn{display:inline-flex;align-items:center;gap:8px;padding:12px 24px;border-radius:var(--r8);font-family:'DM Sans',sans-serif;font-size:13.5px;font-weight:600;cursor:pointer;border:none;transition:all .2s;text-decoration:none}
.btn-primary{background:var(--saffron);color:white;box-shadow:0 4px 12px rgba(232,135,26,.3)}
.btn-primary:hover{background:#D4791A;box-shadow:0 6px 20px rgba(232,135,26,.4);transform:translateY(-1px)}
.btn-ink{background:var(--ink);color:var(--cream)}
.btn-ink:hover{background:#243856;transform:translateY(-1px)}
.btn-ghost{background:transparent;color:var(--ink);border:1.5px solid var(--mist)}
.btn-ghost:hover{border-color:var(--ink)}
.btn-grn{background:var(--forest);color:white;box-shadow:0 4px 12px rgba(26,107,74,.25)}
.btn-sm{padding:8px 16px;font-size:12px}
.btn-lg{padding:16px 32px;font-size:15px;border-radius:var(--r12)}

/* Input */
.ip-input{border:1.5px solid var(--mist);border-radius:var(--r8);padding:12px 16px;font-family:'DM Sans',sans-serif;font-size:13.5px;color:var(--ink);background:white;width:100%;outline:none;transition:all .2s}
.ip-input:focus{border-color:var(--saffron);box-shadow:0 0 0 3px rgba(232,135,26,.12)}
.ip-input::placeholder{color:var(--fog)}

/* Tags */
.tag{display:inline-flex;align-items:center;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:500;gap:4px}
.tag-approve{background:#E8F5EE;color:var(--forest)}
.tag-warn{background:#FEF3E2;color:#B45309}
.tag-info{background:#EAF2FB;color:#1E6FBF}
.tag-pre{background:#F0EBF8;color:#6B21A8}
.tag-neu{background:var(--mist);color:var(--ash)}

/* Trust badge */
.trust-badge{display:inline-flex;align-items:center;gap:6px;background:var(--paper);border:1px solid var(--mist);border-radius:20px;padding:5px 12px 5px 6px;font-size:11.5px;font-weight:500;color:var(--ink)}
.trust-badge .dot{width:20px;height:20px;background:#E8F5EE;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;color:var(--forest);flex-shrink:0}

/* ═══════════════════════════════════════════════
   SECTION: HOMEPAGE MOCKUP
═══════════════════════════════════════════════ */
.mockup-chrome{background:var(--cream);padding:24px}
.browser-bar{background:#E8E3DA;border-radius:var(--r12) var(--r12) 0 0;padding:10px 16px;display:flex;align-items:center;gap:10px}
.bb-dots{display:flex;gap:5px}
.bb-dot{width:10px;height:10px;border-radius:50%}
.bb-url{flex:1;background:white;border-radius:6px;padding:5px 12px;font-family:'DM Mono',monospace;font-size:10px;color:var(--ash);margin:0 16px}
.browser-body{border-radius:0 0 var(--r12) var(--r12);overflow:hidden;box-shadow:var(--s3)}

/* ── ACTUAL INVESTINGPRO UI ── */
/* NAV */
.ip-nav{background:var(--paper);border-bottom:1px solid var(--mist);padding:0 48px;display:flex;align-items:center;gap:0;height:58px;position:relative;z-index:10}
.ip-logo{font-family:'Fraunces',serif;font-size:22px;font-weight:500;color:var(--ink);font-style:italic;margin-right:40px;flex-shrink:0}
.ip-logo span{color:var(--saffron)}
.ip-nav-links{display:flex;gap:0;flex:1}
.ip-nl{padding:0 16px;height:58px;display:flex;align-items:center;font-size:13px;font-weight:500;color:var(--ash);cursor:pointer;border-bottom:2px solid transparent;transition:all .15s;white-space:nowrap}
.ip-nl:hover,.ip-nl.active{color:var(--ink);border-bottom-color:var(--saffron)}
.ip-nav-right{display:flex;align-items:center;gap:12px;margin-left:auto;flex-shrink:0}
.ip-cibil-pill{display:flex;align-items:center;gap:6px;padding:7px 14px;background:#EAF5F0;border-radius:20px;font-size:12px;font-weight:600;color:var(--forest);cursor:pointer}
.ip-cibil-pill .score{font-family:'DM Mono',monospace;font-size:13px;font-weight:500}

/* HERO */
.ip-hero{background:var(--ink);padding:64px 48px 72px;position:relative;overflow:hidden}
.ip-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 80% 60% at 70% 50%,rgba(232,135,26,.12) 0%,transparent 70%)}
.ip-hero::after{content:'';position:absolute;right:0;bottom:0;width:400px;height:300px;background:radial-gradient(ellipse at bottom right,rgba(26,107,74,.15) 0%,transparent 70%)}
.hero-trust{display:inline-flex;align-items:center;gap:6px;background:rgba(245,240,232,.06);border:1px solid rgba(245,240,232,.12);border-radius:20px;padding:6px 14px 6px 8px;margin-bottom:24px;font-size:11.5px;color:rgba(245,240,232,.7);font-weight:500}
.hero-trust .dot{width:18px;height:18px;background:#E8F5EE;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;color:var(--forest)}
.hero-h{font-family:'Fraunces',serif;font-size:clamp(32px,5vw,52px);font-weight:300;color:var(--cream);line-height:1.08;margin-bottom:14px}
.hero-h em{font-style:italic;color:var(--saffron)}
.hero-sub{font-size:15px;color:rgba(245,240,232,.55);line-height:1.7;max-width:520px;margin-bottom:36px}

/* SmartAdvisor */
.smart-box{background:rgba(245,240,232,.06);border:1px solid rgba(245,240,232,.12);border-radius:var(--r16);padding:24px;max-width:580px;backdrop-filter:blur(8px)}
.sb-label{font-family:'DM Mono',monospace;font-size:9.5px;letter-spacing:.14em;text-transform:uppercase;color:var(--saffron);margin-bottom:12px;display:flex;align-items:center;gap:6px}
.sb-label::before{content:'✦';font-size:10px}
.sb-question{font-family:'Fraunces',serif;font-size:18px;font-weight:300;color:var(--cream);margin-bottom:16px;font-style:italic}
.sb-chips{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:16px}
.sb-chip{padding:8px 16px;background:rgba(245,240,232,.08);border:1px solid rgba(245,240,232,.15);border-radius:20px;font-size:12.5px;color:rgba(245,240,232,.7);cursor:pointer;transition:all .2s}
.sb-chip:hover,.sb-chip.picked{background:var(--saffron);border-color:var(--saffron);color:white}
.sb-cta{display:flex;align-items:center;gap:10px;margin-top:4px}
.sb-cta input{background:rgba(255,255,255,.07);border:1px solid rgba(245,240,232,.15);border-radius:var(--r8);padding:11px 16px;color:var(--cream);font-family:'DM Sans',sans-serif;font-size:13px;outline:none;flex:1}
.sb-cta input::placeholder{color:rgba(245,240,232,.3)}
.sb-cta-btn{padding:11px 20px;background:var(--saffron);color:white;border:none;border-radius:var(--r8);font-family:'DM Sans',sans-serif;font-weight:600;font-size:13px;cursor:pointer;white-space:nowrap;box-shadow:0 4px 12px rgba(232,135,26,.3)}
.hero-stats{display:flex;gap:32px;margin-top:36px}
.hstat{display:flex;flex-direction:column}
.hstat .n{font-family:'Fraunces',serif;font-size:26px;font-weight:300;color:var(--cream)}
.hstat .l{font-size:11px;color:rgba(245,240,232,.4);margin-top:1px}

/* INTENT RAIL */
.intent-rail{background:var(--paper);border-bottom:1px solid var(--mist);padding:0 48px;display:flex;gap:0;overflow-x:auto;scrollbar-width:none}
.intent-rail::-webkit-scrollbar{display:none}
.ir-item{padding:18px 24px;display:flex;flex-direction:column;align-items:center;gap:4px;cursor:pointer;border-bottom:3px solid transparent;transition:all .15s;white-space:nowrap;min-width:100px}
.ir-item:hover,.ir-item.on{border-bottom-color:var(--saffron);background:rgba(232,135,26,.02)}
.ir-icon{font-size:22px}
.ir-label{font-size:11.5px;font-weight:600;color:var(--ink)}
.ir-sub{font-size:10px;color:var(--ash)}

/* TRUST BAR */
.trust-bar{background:var(--forest);padding:12px 48px;display:flex;align-items:center;gap:32px}
.tb-item{display:flex;align-items:center;gap:7px;font-size:12px;color:rgba(245,240,232,.85);font-weight:500}
.tb-item .ico{font-size:14px}
.tb-sep{width:1px;height:16px;background:rgba(245,240,232,.15)}

/* SECTION HEADERS */
.ip-sec{padding:56px 48px}
.ip-sec-light{background:var(--paper)}
.ip-sec-cream{background:var(--cream)}
.sec-kicker{font-family:'DM Mono',monospace;font-size:9.5px;letter-spacing:.16em;text-transform:uppercase;color:var(--saffron);margin-bottom:10px}
.sec-h{font-family:'Fraunces',serif;font-size:clamp(24px,3vw,36px);font-weight:300;color:var(--ink);margin-bottom:6px}
.sec-h em{font-style:italic;color:var(--saffron)}
.sec-sub{font-size:13.5px;color:var(--ash);margin-bottom:36px;max-width:500px;line-height:1.65}

/* CARD GRID */
.card-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.cc-card{background:var(--paper);border:1.5px solid var(--mist);border-radius:var(--r16);overflow:hidden;transition:all .25s;cursor:pointer}
.cc-card:hover{border-color:var(--saffron);box-shadow:var(--s2);transform:translateY(-2px)}
.cc-card-top{padding:20px 20px 16px;border-bottom:1px solid var(--mist);display:flex;align-items:flex-start;gap:14px}
.cc-img{width:52px;height:32px;border-radius:4px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;letter-spacing:.04em;color:white}
.cc-card-name{font-size:13.5px;font-weight:600;color:var(--ink);line-height:1.3}
.cc-card-bank{font-size:11px;color:var(--ash);margin-top:2px}
.cc-approval{margin-left:auto;display:flex;align-items:center;gap:4px;flex-shrink:0}
.ap-ring{width:36px;height:36px;border-radius:50%;border:2.5px solid var(--forest);display:flex;align-items:center;justify-content:center;flex-direction:column;line-height:1.1}
.ap-pct{font-family:'DM Mono',monospace;font-size:9px;font-weight:500;color:var(--forest)}
.ap-lbl{font-size:7px;color:var(--ash)}
.cc-card-body{padding:16px 20px}
.cc-reward{font-size:22px;font-weight:700;color:var(--ink);font-family:'Fraunces',serif;line-height:1}
.cc-reward-label{font-size:11px;color:var(--ash);margin-top:2px}
.cc-tags{display:flex;flex-wrap:wrap;gap:5px;margin-top:12px}
.cc-card-footer{padding:12px 20px;background:rgba(232,135,26,.03);border-top:1px solid var(--mist);display:flex;align-items:center;justify-content:space-between}
.cc-fee{font-size:11.5px;color:var(--ash)}
.cc-fee strong{color:var(--ink)}
.cc-apply-btn{padding:7px 16px;background:var(--saffron);color:white;border-radius:6px;font-size:12px;font-weight:600;border:none;cursor:pointer}
.cc-apply-btn:hover{background:#D4791A}

/* EDITORIAL QUOTE */
.editorial-quote{background:var(--ink);padding:64px 80px;position:relative;overflow:hidden}
.eq-mark{font-family:'Fraunces',serif;font-size:120px;color:rgba(232,135,26,.15);position:absolute;top:20px;left:60px;line-height:1;font-style:italic}
.eq-text{font-family:'Fraunces',serif;font-size:clamp(22px,3vw,34px);font-weight:300;font-style:italic;color:var(--cream);line-height:1.4;max-width:680px;margin:0 auto;text-align:center;position:relative;z-index:1}
.eq-text em{color:var(--saffron)}
.eq-credit{text-align:center;margin-top:20px;font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:rgba(245,240,232,.35);position:relative;z-index:1}

/* FEATURE SECTION */
.feature-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px}
.feat-card{background:var(--paper);border-radius:var(--r16);padding:28px;border:1.5px solid var(--mist)}
.feat-icon-wrap{width:44px;height:44px;border-radius:var(--r12);display:flex;align-items:center;justify-content:center;font-size:22px;margin-bottom:16px}
.feat-h{font-size:15px;font-weight:600;color:var(--ink);margin-bottom:6px;font-family:'Fraunces',serif;font-style:italic}
.feat-p{font-size:12.5px;color:var(--ash);line-height:1.65}
.feat-proof{display:flex;align-items:center;gap:6px;margin-top:14px;font-size:11.5px;color:var(--forest);font-weight:500}
.feat-proof::before{content:'→';font-size:12px}

/* CIBIL SIMULATOR WIDGET */
.cibil-sim{background:var(--paper);border-radius:var(--r16);padding:28px;border:1.5px solid var(--mist);max-width:460px}
.sim-header{display:flex;align-items:center;gap:10px;margin-bottom:20px}
.sim-score-ring{position:relative;width:72px;height:72px;flex-shrink:0}
.sim-score-ring svg{position:absolute;top:0;left:0;width:100%;height:100%;transform:rotate(-90deg)}
