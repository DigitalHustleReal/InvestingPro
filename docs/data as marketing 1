        <pre><span class="cm">// next.js getStaticProps — MF NAV from mfapi.in</span>
<span class="kw">export async function</span> <span class="fn">getStaticProps</span>({ params }) {
  <span class="kw">const</span> code = params.schemeCode;
  <span class="kw">const</span> res = <span class="kw">await</span> fetch(
    <span class="str">`https://api.mfapi.in/mf/${code}`</span>
  );
  <span class="kw">const</span> { meta, data } = <span class="kw">await</span> res.json();

  <span class="cm">// 'data' = array of {date, nav} objects</span>
  <span class="cm">// Calculate 1Y, 3Y, 5Y CAGR from data</span>
  <span class="kw">const</span> currentNAV = parseFloat(data[<span class="num">0</span>].nav);
  <span class="kw">const</span> nav1yAgo = <span class="fn">getNavDaysAgo</span>(data, <span class="num">365</span>);
  <span class="kw">const</span> returns1Y = ((currentNAV / nav1yAgo) - <span class="num">1</span>) * <span class="num">100</span>;

  <span class="kw">return</span> {
    props: { meta, data: data.slice(<span class="num">0</span>, <span class="num">365</span>), returns1Y },
    revalidate: <span class="num">86400</span> <span class="cm">// Regenerate daily</span>
  };
}</pre>
