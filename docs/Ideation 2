<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>InvestingPro — India's Most Methodical Financial Comparison</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600;1,700&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════════════════
   INVESTINGPRO.IN — HOMEPAGE
   Tone: Editorial authority · Warm expertise · Indian
   Trust model: Institutional, methodology-first
   ═══════════════════════════════════════════════════ */
:root{
  --ink:#1B2A4A; --ink2:#243859;
  --saf:#E8871A; --saf2:#F5A045; --saf-dim:rgba(232,135,26,.1);
  --grn:#1A6B4A; --grn2:#4CAF7D; --grn-dim:rgba(26,107,74,.09);
  --cream:#F5F0E8; --cream2:#EDE8DF;
  --paper:#FFFDF8; --paper2:#FAF6EE;
  --mist:#E4DEDA; --bone:#D4CDBE;
  --ash:#7A8799; --fog:#B0BAC8;
  --red:#C0392B; --sky:#1E6FBF; --warn:#B45309; --purple:#6B21A8;
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;font-size:14px}
body{font-family:'DM Sans',system-ui,sans-serif;background:var(--cream);color:var(--ink);line-height:1.65;-webkit-font-smoothing:antialiased}

/* ─── SKIP LINK ─── */
.skip{position:absolute;left:-9999px;top:4px;padding:6px 12px;background:var(--saf);color:#fff;border-radius:4px;font-size:12px;z-index:999}
.skip:focus{left:4px}

/* ─── TOP ANNOUNCEMENT BAR ─── */
.announce-bar{
  background:var(--ink);
  padding:8px 0;
  text-align:center;
  font-size:12px;
  color:rgba(245,240,232,.55);
  display:flex;
  align-items:center;
  justify-content:center;
  gap:6px;
  position:relative;
}
.announce-bar a{color:var(--saf);text-decoration:none;font-weight:500}
.ab-live{
  display:inline-flex;align-items:center;gap:5px;
  background:rgba(26,107,74,.15);border:1px solid rgba(26,107,74,.3);
  border-radius:20px;padding:2px 9px;font-size:11px;color:var(--grn2);font-weight:600
}
.ab-dot{width:5px;height:5px;background:var(--grn2);border-radius:50%;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}

/* ─── MAIN NAV ─── */
.nav-wrap{position:sticky;top:0;z-index:400;box-shadow:0 1px 0 var(--mist)}
.main-nav{
  background:var(--paper);height:58px;
  display:flex;align-items:stretch;padding:0 28px;
}
.logo{
  font-family:'Playfair Display',serif;font-size:20px;font-style:italic;
  font-weight:400;color:var(--ink);text-decoration:none;
  display:flex;align-items:center;margin-right:24px;flex-shrink:0;
}
.logo .pro{color:var(--saf)}
.logo .in-badge{
  font-size:9.5px;font-style:normal;font-weight:600;letter-spacing:.05em;
  color:var(--ash);margin-left:4px;align-self:flex-end;margin-bottom:4px;
}

/* Desktop nav items */
.nav-items{display:flex;height:58px;flex:1}
.nav-item{position:static;height:58px}
.nav-trigger{
  height:58px;padding:0 13px;display:flex;align-items:center;gap:4px;
  font-size:12.5px;font-weight:500;color:var(--ash);cursor:pointer;
  border:none;background:none;border-bottom:2px solid transparent;
  white-space:nowrap;transition:color .14s,border-color .14s;font-family:inherit;
}
.nav-trigger:hover{color:var(--ink)}
.nav-trigger.has-mega:hover,.nav-trigger.open{color:var(--ink);border-bottom-color:var(--saf)}
.nt-chevron{width:9px;height:9px;transition:transform .18s;opacity:.45;margin-top:1px}
.nav-trigger.open .nt-chevron{transform:rotate(180deg);opacity:.7}

/* FREE CIBIL — special green link */
.nav-cibil{
  height:58px;padding:0 13px;display:flex;align-items:center;
  font-size:12.5px;font-weight:600;color:var(--grn);
  cursor:pointer;border:none;background:none;border-bottom:2px solid transparent;
  font-family:inherit;transition:border-color .14s;white-space:nowrap;
}
.nav-cibil:hover{border-bottom-color:var(--grn)}

.nav-right{margin-left:auto;display:flex;align-items:center;gap:8px;flex-shrink:0;padding-left:16px}
.btn-sm{
  padding:7px 14px;border-radius:6px;font-size:12px;font-weight:600;
  cursor:pointer;font-family:inherit;border:none;white-space:nowrap;transition:all .14s;
}
.btn-outline{background:transparent;border:1px solid var(--mist);color:var(--ash)}
.btn-outline:hover{border-color:var(--ink);color:var(--ink)}
.btn-saf{background:var(--saf);color:#fff}
.btn-saf:hover{background:#D4791A}
.btn-grn{
  display:flex;align-items:center;gap:5px;
  background:var(--grn-dim);border:1px solid rgba(26,107,74,.2);color:var(--grn);
  border-radius:20px;padding:6px 14px;
}
.btn-grn::before{content:'';width:6px;height:6px;border-radius:50%;background:var(--grn);flex-shrink:0}
.btn-grn:hover{background:rgba(26,107,74,.15)}
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:4px;background:none;border:none}
.hamburger span{width:20px;height:1.5px;background:var(--ash);border-radius:1px;display:block;transition:all .2s}

/* ─── MEGA MENU ─── */
.mega-overlay{
  display:none;position:fixed;top:58px;left:0;right:0;bottom:0;
  background:rgba(27,42,74,.2);backdrop-filter:blur(2px);z-index:300;
}
.mega-overlay.open{display:block}
.mega-panel{
  display:none;position:absolute;top:58px;left:0;right:0;
  background:var(--paper);border-top:2px solid var(--saf);
  border-bottom:1px solid var(--mist);
  box-shadow:0 12px 40px rgba(27,42,74,.1);z-index:350;
}
.mega-panel.open{display:block}
.mega-inner{
  max-width:1100px;margin:0 auto;padding:24px 28px;
  display:grid;gap:0;
}
.mega-cols{display:flex;gap:0}
.mega-col{flex:1;padding:0 20px;border-right:1px solid var(--mist)}
.mega-col:first-child{padding-left:0}
.mega-col:last-child{border:none}
.mc-kicker{
  font-size:9px;letter-spacing:.14em;text-transform:uppercase;font-weight:700;
  color:var(--saf);margin-bottom:12px;
}
.mc-link{
  display:flex;align-items:flex-start;gap:10px;padding:7px 8px;
  border-radius:8px;cursor:pointer;text-decoration:none;transition:background .12s;margin-bottom:2px;
}
.mc-link:hover{background:var(--cream)}
.mc-icon{
  width:30px;height:30px;border-radius:7px;display:flex;align-items:center;
  justify-content:center;font-size:14px;flex-shrink:0;margin-top:1px;
}
.mc-text .n{font-size:12.5px;font-weight:500;color:var(--ink);line-height:1.2}
.mc-text .s{font-size:11px;color:var(--ash);margin-top:1px;line-height:1.3}
.mega-live{
  background:var(--cream);border-radius:10px;padding:13px 14px;
  border:1px solid var(--mist);min-width:180px;
}
.ml-kicker{font-size:9px;letter-spacing:.1em;text-transform:uppercase;font-weight:700;color:var(--ash);margin-bottom:8px}
.ml-row{
  display:flex;align-items:center;justify-content:space-between;
  padding:5px 0;border-bottom:1px solid var(--mist);font-size:12px;
}
.ml-row:last-child{border:none}
.ml-name{color:var(--ash)}
.ml-val{font-weight:600;font-size:12px}
.ml-badge{padding:1px 7px;border-radius:8px;font-size:10.5px;font-weight:700}
.mega-cta-row{display:flex;align-items:center;justify-content:space-between;margin-top:16px;padding-top:14px;border-top:1px solid var(--mist)}
.mega-cta-link{font-size:12px;color:var(--saf);font-weight:600;text-decoration:none;cursor:pointer}
.mega-cta-link:hover{text-decoration:underline}

/* ─── TRUST BAR ─── */
.trust-bar{
  background:var(--grn);padding:7px 0;
  display:flex;overflow-x:auto;scrollbar-width:none;
}
.trust-bar::-webkit-scrollbar{display:none}
.trust-bar-inner{
  max-width:1100px;margin:0 auto;padding:0 28px;
  display:flex;align-items:center;gap:0;min-width:max-content;
}
.tb-item{
  display:flex;align-items:center;gap:6px;
  font-size:11.5px;color:rgba(245,240,232,.82);font-weight:500;
  padding:0 16px;border-right:1px solid rgba(245,240,232,.15);white-space:nowrap;
}
.tb-item:first-child{padding-left:0}
.tb-item:last-child{border:none}
.tb-check{
  width:15px;height:15px;border-radius:50%;background:rgba(245,240,232,.15);
  display:flex;align-items:center;justify-content:center;font-size:8px;color:rgba(245,240,232,.9);
  flex-shrink:0;
}

/* ─── HERO ─── */
.hero{
  background:var(--ink);padding:60px 0 56px;
  position:relative;overflow:hidden;
}
.hero::before{
  content:'';position:absolute;right:-80px;top:-80px;
  width:500px;height:500px;
  background:radial-gradient(circle at center,rgba(232,135,26,.07) 0%,transparent 65%);
  pointer-events:none;
}
.hero::after{
  content:'';position:absolute;left:20%;bottom:0;
  width:60%;height:1px;background:rgba(232,135,26,.15);
}
.hero-inner{
  max-width:1100px;margin:0 auto;padding:0 28px;
  display:grid;grid-template-columns:1fr 400px;gap:48px;align-items:center;
  position:relative;z-index:1;
}
.hero-badge{
  display:inline-flex;align-items:center;gap:7px;
  background:rgba(245,240,232,.07);border:1px solid rgba(245,240,232,.14);
  border-radius:20px;padding:5px 13px;margin-bottom:16px;
  font-size:11px;color:rgba(245,240,232,.6);font-weight:500;
}
.hb-dot{width:5px;height:5px;background:var(--grn2);border-radius:50%;animation:pulse 2s infinite}
.hero h1{
  font-family:'Playfair Display',serif;font-size:42px;font-weight:400;
  font-style:italic;color:#F5F0E8;line-height:1.08;margin-bottom:14px;
}
.hero h1 em{color:var(--saf);font-style:italic}
.hero-sub{
  font-size:14.5px;color:rgba(245,240,232,.48);line-height:1.75;
  max-width:400px;margin-bottom:24px;
}
.hero-stats{display:flex;gap:24px;align-items:center;margin-bottom:20px}
.hs{}.hs-n{font-family:'Playfair Display',serif;font-size:22px;color:#F5F0E8}
.hs-l{font-size:10.5px;color:rgba(245,240,232,.32);margin-top:1px}
.hs-div{width:1px;height:30px;background:rgba(245,240,232,.1)}
.method-note{
  display:flex;align-items:flex-start;gap:8px;
  background:rgba(245,240,232,.05);border:1px solid rgba(245,240,232,.1);
  border-radius:8px;padding:10px 13px;font-size:11.5px;color:rgba(245,240,232,.4);
  max-width:420px;line-height:1.6;
}
.method-note strong{color:rgba(245,240,232,.65)}
.method-note a{color:var(--saf);text-decoration:none}

/* ─── SMART ADVISOR WIDGET ─── */
.smart-widget{
  background:rgba(245,240,232,.07);border:1px solid rgba(245,240,232,.13);
  border-radius:14px;padding:22px;
}
.sw-kicker{
  font-size:9px;letter-spacing:.14em;text-transform:uppercase;font-weight:700;
  color:var(--saf);margin-bottom:4px;display:flex;align-items:center;gap:6px;
}
.sw-kicker::before{content:'✦';font-size:10px}
.sw-q{
  font-family:'Playfair Display',serif;font-size:15px;font-style:italic;
  color:#F5F0E8;margin-bottom:14px;line-height:1.3;
}
.sw-chips{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:14px}
.sw-chip{
  padding:6px 13px;background:rgba(245,240,232,.07);
  border:1px solid rgba(245,240,232,.14);border-radius:20px;
  font-size:12px;color:rgba(245,240,232,.6);cursor:pointer;
  transition:all .15s;font-family:inherit;
}
.sw-chip:hover,.sw-chip.sel{
  background:var(--saf);border-color:var(--saf);color:#fff;
}
.sw-row{display:flex;gap:7px;margin-bottom:9px}
.sw-input{
  flex:1;background:rgba(255,255,255,.08);border:1px solid rgba(245,240,232,.14);
  border-radius:7px;padding:9px 12px;color:#F5F0E8;font-family:inherit;
  font-size:12.5px;outline:none;transition:border-color .15s;
}
.sw-input::placeholder{color:rgba(245,240,232,.25)}
.sw-input:focus{border-color:rgba(232,135,26,.5)}
.sw-btn{
  padding:9px 16px;background:var(--saf);color:#fff;border:none;
  border-radius:7px;font-family:inherit;font-size:12.5px;font-weight:600;
  cursor:pointer;white-space:nowrap;transition:background .14s;
}
.sw-btn:hover{background:#D4791A}
.sw-note{font-size:11px;color:rgba(245,240,232,.22)}
.sw-divider{
  display:flex;align-items:center;gap:8px;margin:12px 0;
  font-size:11px;color:rgba(245,240,232,.2);
}
.sw-divider::before,.sw-divider::after{content:'';flex:1;height:1px;background:rgba(245,240,232,.1)}
.sw-cibil{
  display:flex;align-items:center;gap:10px;
  background:rgba(26,107,74,.12);border:1px solid rgba(26,107,74,.2);
  border-radius:8px;padding:10px 12px;cursor:pointer;transition:background .14s;
}
.sw-cibil:hover{background:rgba(26,107,74,.18)}
.cibil-mini-ring{position:relative;width:36px;height:36px;flex-shrink:0}
.cibil-mini-ring svg{width:36px;height:36px;transform:rotate(-90deg)}
.cmr-inner{
  position:absolute;inset:0;display:flex;align-items:center;
  justify-content:center;font-size:9.5px;font-weight:700;color:var(--grn2);
}
.sc-text .sc-label{font-size:12px;font-weight:600;color:#F5F0E8}
.sc-text .sc-sub{font-size:11px;color:rgba(245,240,232,.4)}

/* ─── INTENT RAIL ─── */
.intent-rail{
  background:var(--paper);border-bottom:1px solid var(--mist);
  display:flex;overflow-x:auto;scrollbar-width:none;
}
.intent-rail::-webkit-scrollbar{display:none}
.ir-inner{
  max-width:1100px;margin:0 auto;padding:0 28px;
  display:flex;min-width:max-content;width:100%;
}
.ir-item{
  display:flex;flex-direction:column;align-items:center;gap:3px;
  padding:10px 20px;cursor:pointer;border-bottom:2.5px solid transparent;
  transition:border-color .14s;white-space:nowrap;flex-shrink:0;
  text-decoration:none;
}
.ir-item:hover{border-bottom-color:rgba(232,135,26,.35)}
.ir-item.active{border-bottom-color:var(--saf)}
.ir-icon{font-size:18px;line-height:1}
.ir-label{font-size:12px;font-weight:600;color:var(--ink)}
.ir-sub{font-size:10px;color:var(--ash)}

/* ─── EDITORIAL NOTE ─── */
.ed-note{
  background:rgba(26,107,74,.06);border:1px solid rgba(26,107,74,.16);
  border-radius:10px;padding:13px 16px;display:flex;align-items:flex-start;gap:10px;
}
.en-icon{
  width:26px;height:26px;border-radius:50%;background:var(--grn);
  display:flex;align-items:center;justify-content:center;
  font-size:11px;color:#fff;flex-shrink:0;font-weight:700;margin-top:1px;
}
.en-content{}
.en-label{
  font-size:9.5px;letter-spacing:.1em;text-transform:uppercase;
  font-weight:700;color:var(--grn);margin-bottom:3px;
}
.en-text{font-size:12.5px;color:#1A3D2B;line-height:1.6}

/* ─── METHODOLOGY STRIP ─── */
.method-strip{
  background:rgba(26,107,74,.04);border-top:1px solid rgba(26,107,74,.1);
  border-bottom:1px solid rgba(26,107,74,.1);
  padding:9px 0;
}
.ms-inner{
  max-width:1100px;margin:0 auto;padding:0 28px;
  display:flex;align-items:center;gap:10px;flex-wrap:wrap;
  font-size:12.5px;color:#1A3D2B;
}
.ms-inner a{color:var(--sky);text-decoration:none;font-weight:500}
.ms-inner a:hover{text-decoration:underline}
.ms-chips{display:flex;gap:6px;flex-wrap:wrap;margin-left:4px}
.ms-chip{
  padding:2px 9px;border-radius:8px;font-size:11px;font-weight:600;
  background:#E8F5EE;color:var(--grn);white-space:nowrap;
}

/* ─── FILTER BAR ─── */
.filter-bar{
  background:var(--paper);border-bottom:1px solid var(--mist);
  padding:10px 0;position:sticky;top:58px;z-index:100;
}
.fb-inner{
  max-width:1100px;margin:0 auto;padding:0 28px;
  display:flex;align-items:center;gap:7px;overflow-x:auto;scrollbar-width:none;
}
.fb-inner::-webkit-scrollbar{display:none}
.fb-label{
  font-size:10px;letter-spacing:.1em;text-transform:uppercase;
  font-weight:700;color:var(--ash);flex-shrink:0;
}
.fb-chip{
  padding:5px 13px;border:1px solid var(--mist);border-radius:20px;
  font-size:12px;color:var(--ash);background:var(--paper);cursor:pointer;
  white-space:nowrap;transition:all .13s;font-family:inherit;
}
.fb-chip:hover{border-color:var(--saf);color:var(--saf)}
.fb-chip.on{background:var(--saf);border-color:var(--saf);color:#fff}
.fb-right{
  margin-left:auto;font-size:12px;font-weight:500;color:var(--sky);
  cursor:pointer;white-space:nowrap;flex-shrink:0;
}

/* ─── SECTION WRAPPER ─── */
.section{padding:40px 0}
.section.bg-paper{background:var(--paper)}
.section.bg-cream{background:var(--cream)}
.section.bg-ink{background:var(--ink)}
.inner{max-width:1100px;margin:0 auto;padding:0 28px}
.section-hd{
  display:flex;align-items:flex-end;justify-content:space-between;
  gap:16px;margin-bottom:20px;
}
.sh-left{}
.kicker{
  font-size:9.5px;letter-spacing:.16em;text-transform:uppercase;
  font-weight:700;color:var(--saf);margin-bottom:5px;
}
.sh-title{
  font-family:'Playfair Display',serif;font-size:24px;
  font-weight:400;font-style:italic;color:var(--ink);margin-bottom:4px;
}
.sh-title em{color:var(--saf)}
.sh-sub{font-size:12.5px;color:var(--ash);max-width:440px;line-height:1.6}
.sh-link{font-size:12.5px;color:var(--saf);text-decoration:none;font-weight:600;flex-shrink:0;padding-bottom:8px}
.sh-link:hover{text-decoration:underline}

/* ─── CARD ROW (horizontal listing row) ─── */
.card-row{
  background:var(--paper);border:1px solid var(--mist);border-radius:14px;
  overflow:hidden;margin-bottom:10px;
  transition:border-color .18s,box-shadow .18s;
}
.card-row:hover{border-color:rgba(232,135,26,.35);box-shadow:0 4px 18px rgba(27,42,74,.07)}
.cr-pick-strip{
  background:var(--saf-dim);padding:5px 18px;
  border-bottom:1px solid rgba(232,135,26,.12);
  display:flex;align-items:center;gap:8px;
  font-size:9.5px;letter-spacing:.06em;text-transform:uppercase;
  color:var(--saf);font-weight:700;
}
.cr-body{display:grid;grid-template-columns:108px 1fr 130px;align-items:stretch}
.cr-left{
  padding:14px 12px;display:flex;flex-direction:column;align-items:center;
  gap:7px;border-right:1px solid var(--mist);
}
.card-thumb{
  width:74px;height:46px;border-radius:7px;
  display:flex;align-items:center;justify-content:center;
  font-size:11px;font-weight:700;color:#fff;font-family:'DM Mono',monospace;
}
.cr-bank{font-size:10px;color:var(--ash);text-align:center;line-height:1.3}
.cr-stars{font-size:11px;color:#F59E0B;letter-spacing:-1px}
.cr-mid{padding:14px 18px}
.cr-name{font-size:14.5px;font-weight:600;color:var(--ink);margin-bottom:4px}
.cr-desc{font-size:12.5px;color:var(--ash);margin-bottom:10px;line-height:1.55}
.cr-pills{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:10px}
.cr-pill{
  display:flex;align-items:center;gap:4px;
  padding:4px 9px;border-radius:6px;font-size:11.5px;font-weight:500;
}
.cr-pill.pos{background:#F0F9F4;color:var(--grn)}
.cr-pill.neg{background:#FEF0EE;color:var(--red)}
.cr-pill.info{background:#EAF2FB;color:var(--sky)}
.cr-meta{display:flex;gap:18px}
.cm-item .v{font-size:13px;font-weight:600;color:var(--ink)}
.cm-item .l{font-size:10.5px;color:var(--ash);margin-top:1px}
.cr-right{
  padding:14px 12px;display:flex;flex-direction:column;
  align-items:center;justify-content:center;gap:9px;
  border-left:1px solid var(--mist);
}
.approval-ring{position:relative;width:54px;height:54px}
.approval-ring svg{width:54px;height:54px;transform:rotate(-90deg)}
.ar-center{
  position:absolute;inset:0;display:flex;flex-direction:column;
  align-items:center;justify-content:center;line-height:1.1;
}
.ar-pct{font-size:12px;font-weight:700}
.ar-label{font-size:8.5px;color:var(--ash)}
.cr-apply{
