<script>
/* ── Mega menu ── */
let openMega=null,openTrigger=null;
function toggleMega(id,trigger){
  if(openMega===id){closeAllMega();return}
  closeAllMega();
  openMega=id;openTrigger=trigger;
  document.getElementById('mega-'+id).classList.add('open');
  document.getElementById('mega-overlay').classList.add('open');
  trigger.classList.add('open');
  trigger.setAttribute('aria-expanded','true');
}
function closeAllMega(){
  document.querySelectorAll('.mega-panel.open').forEach(p=>p.classList.remove('open'));
  document.getElementById('mega-overlay').classList.remove('open');
  document.querySelectorAll('.nav-trigger.open').forEach(t=>{
    t.classList.remove('open');
    t.setAttribute('aria-expanded','false');
  });
  openMega=null;openTrigger=null;
}
document.addEventListener('keydown',e=>{if(e.key==='Escape')closeAllMega()});

/* ── Mobile drawer ── */
function openDrawer(){
  document.getElementById('mob-drawer').classList.add('open');
  document.getElementById('mob-overlay').classList.add('open');
  document.body.style.overflow='hidden';
}
function closeDrawer(){
  document.getElementById('mob-drawer').classList.remove('open');
  document.getElementById('mob-overlay').classList.remove('open');
  document.body.style.overflow='';
}

/* ── Smart Advisor chips ── */
function selChip(el){
  el.closest('.sw-chips').querySelectorAll('.sw-chip').forEach(c=>c.classList.remove('sel'));
  el.classList.add('sel');
}
function findCard(){
  const chip=document.querySelector('.sw-chip.sel');
  const cat=chip?chip.textContent:'spending';
  const inp=document.querySelector('.sw-input').value;
  alert('Finding best cards for '+cat+(inp?' with ₹'+parseInt(inp).toLocaleString('en-IN')+'/month spend':'')+'...\n\n(Connect to API for live results)');
}

/* ── CIBIL Simulator ── */
let baseScore=748,activeDeltas={};
function toggleAction(el,delta){
  const key=el.dataset.delta+'_'+el.querySelector('.sa-title').textContent.slice(0,20);
  if(activeDeltas[key]){
    delete activeDeltas[key];
    el.style.background='';
    el.style.borderColor='';
  }else{
    activeDeltas[key]=delta;
    el.style.background=delta>0?'rgba(26,107,74,.06)':'rgba(192,57,43,.06)';
    el.style.borderColor=delta>0?'rgba(26,107,74,.2)':'rgba(192,57,43,.2)';
  }
  updateScore();
}
function updateScore(){
  let s=baseScore;
  Object.values(activeDeltas).forEach(d=>s+=d);
  s=Math.min(900,Math.max(300,s));
  document.getElementById('sim-score').textContent=s;
  const labels={excellent:[800,'Excellent'],vgood:[750,'Very Good'],good:[700,'Good'],fair:[650,'Fair'],poor:[0,'Poor']};
  let lbl='Poor',col='#C0392B';
  if(s>=800){lbl='Excellent';col='#1A6B4A'}
  else if(s>=750){lbl='Very Good';col='#1A6B4A'}
  else if(s>=700){lbl='Good';col='#B45309'}
  else if(s>=650){lbl='Fair';col='#B45309'}
  document.getElementById('sim-label').textContent=lbl;
  document.getElementById('sim-score').style.color=col;
  const circle=document.getElementById('sim-circle');
  const pct=(s-300)/600;
  const dash=Math.round(pct*365);
  circle.setAttribute('stroke-dasharray',dash+' 365');
  circle.setAttribute('stroke',col);
}

/* ── Filter chips ── */
document.querySelectorAll('.fb-chip').forEach(c=>{
  c.addEventListener('click',function(){
    this.closest('.fb-inner').querySelectorAll('.fb-chip').forEach(x=>x.classList.remove('on'));
    this.classList.add('on');
  });
});

/* ── Newsletter ── */
function subscribeNL(e){
  e.preventDefault();
  const btn=e.target.querySelector('.nl-btn');
  btn.textContent='Subscribed! ✓';
  btn.style.background='#1A6B4A';
  e.target.querySelector('.nl-input').value='';
  setTimeout(()=>{btn.textContent='Subscribe Free →';btn.style.background=''},3000);
}

/* ── Intent rail active state on scroll ── */
const irItems=document.querySelectorAll('.ir-item');
const sections=['cards','cibil','rates','newsletter'];
window.addEventListener('scroll',()=>{
  let current='';
  sections.forEach(id=>{
    const s=document.getElementById(id);
    if(s&&window.scrollY>=s.offsetTop-120)current=id;
  });
},{passive:true});
</script>
