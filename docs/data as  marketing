    <div class="result-row"><span class="result-lbl">Post-tax Return</span><span class="result-val">${((gain-taxable)/p*100/y).toFixed(2)}% p.a.</span></div>`;
}

// Real Return
function calcRealReturn(){
  const fd=parseFloat(document.getElementById('rr-fd')?.value)||7;
  const inf=parseFloat(document.getElementById('rr-inf')?.value)||4;
  const tax=parseFloat(document.getElementById('rr-tax')?.value)||30;
