<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>InvestingPro — Engineering as Marketing</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=IBM+Plex+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#03050A;--c1:#080D18;--c2:#0D1422;--c3:#121B2E;--c4:#1A2540;
  --br:#1C2840;--br2:#243354;--br3:#2C3F68;
  --t1:#EEF2FF;--t2:#8FA3CC;--t3:#445570;--t4:#2A3550;
  --vi:#7C6FFF;--vi2:#6A5EE8;--vix:rgba(124,111,255,.12);--vib:rgba(124,111,255,.06);
  --gr:#05D98A;--grx:rgba(5,217,138,.1);--grd:rgba(5,217,138,.05);
  --am:#FFAA33;--amx:rgba(255,170,51,.1);
  --cy:#00DCFF;--cyx:rgba(0,220,255,.09);
  --re:#FF4D6A;--rex:rgba(255,77,106,.1);
  --pk:#FF2D87;--pkx:rgba(255,45,135,.1);
  --yw:#FFE566;--ywx:rgba(255,229,102,.1);
  --r8:8px;--r10:10px;--r12:12px;--r16:16px;--r20:20px;
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{background:var(--bg);color:var(--t1);font-family:'IBM Plex Sans',system-ui,sans-serif;font-size:13px;-webkit-font-smoothing:antialiased;line-height:1.6}

/* ── LAYOUT ── */
.app{display:flex;min-height:100vh}
.sidebar{width:220px;background:var(--c1);border-right:1px solid var(--br);position:fixed;top:0;bottom:0;left:0;overflow-y:auto;scrollbar-width:none;display:flex;flex-direction:column;z-index:40}
.sidebar::-webkit-scrollbar{display:none}
.main{margin-left:220px;flex:1;display:flex;flex-direction:column}
.topbar{height:52px;background:var(--c1);border-bottom:1px solid var(--br);display:flex;align-items:center;padding:0 24px;gap:12px;position:sticky;top:0;z-index:30;flex-shrink:0}
.content-area{padding:28px 28px;flex:1}

/* ── SIDEBAR ── */
.sb-brand{padding:18px 16px 14px;border-bottom:1px solid var(--br)}
.sb-logo{font-family:'Syne',sans-serif;font-size:15px;font-weight:800;color:var(--t1);letter-spacing:-.04em}
.sb-logo em{color:var(--gr);font-style:normal}
.sb-tagline{font-family:'JetBrains Mono',monospace;font-size:8.5px;color:var(--t3);margin-top:2px;letter-spacing:.04em}
.sb-sect{padding:14px 14px 4px;font-family:'JetBrains Mono',monospace;font-size:7.5px;letter-spacing:.2em;text-transform:uppercase;color:var(--t4)}
.sb-item{display:flex;align-items:center;gap:8px;padding:8px 13px;margin:1px 8px;border-radius:var(--r8);cursor:pointer;font-size:12px;color:var(--t3);transition:all .13s;user-select:none}
.sb-item:hover{background:var(--c2);color:var(--t2)}
.sb-item.active{background:var(--vix);color:var(--vi);font-weight:600}
.sb-item-ico{font-size:14px;width:18px;text-align:center;flex-shrink:0}
.sb-cnt{margin-left:auto;font-family:'JetBrains Mono',monospace;font-size:8.5px;background:var(--c3);padding:1px 6px;border-radius:8px;color:var(--t3)}
.sb-item.active .sb-cnt{background:var(--vix);color:var(--vi)}
.sb-footer{margin-top:auto;padding:14px;border-top:1px solid var(--br)}
.sb-cta{background:linear-gradient(135deg,var(--vi),var(--cy));border-radius:var(--r8);padding:10px 12px;font-size:11.5px;font-weight:700;color:#fff;cursor:pointer;text-align:center;transition:opacity .14s}
.sb-cta:hover{opacity:.9}

/* ── TOPBAR ── */
.tb-title{font-family:'Syne',sans-serif;font-size:16px;font-weight:800;color:var(--t1);letter-spacing:-.04em;flex:1}
.tb-badges{display:flex;gap:7px;align-items:center}
.tb-badge{padding:4px 11px;border-radius:20px;font-size:10px;font-weight:600;font-family:'JetBrains Mono',monospace}

/* ── BUTTONS ── */
.btn{display:inline-flex;align-items:center;gap:5px;padding:7px 14px;border-radius:var(--r8);font-family:'IBM Plex Sans',sans-serif;font-size:12px;font-weight:600;cursor:pointer;border:none;transition:all .14s;white-space:nowrap}
.btn-primary{background:var(--vi);color:#fff}.btn-primary:hover{background:var(--vi2);transform:translateY(-1px);box-shadow:0 6px 20px rgba(124,111,255,.3)}
.btn-gr{background:var(--gr);color:#000}.btn-gr:hover{opacity:.9;transform:translateY(-1px)}
.btn-ghost{background:transparent;border:1px solid var(--br2);color:var(--t2)}.btn-ghost:hover{border-color:var(--vi);color:var(--vi)}
.btn-sm{padding:5px 11px;font-size:11px}
.btn-xs{padding:3px 8px;font-size:10.5px}

/* ── PAGE HEADER ── */
.pg-hd{margin-bottom:26px}
.pg-eyebrow{font-family:'JetBrains Mono',monospace;font-size:8.5px;letter-spacing:.2em;text-transform:uppercase;color:var(--vi);margin-bottom:7px;display:flex;align-items:center;gap:8px}
.pg-eyebrow::before{content:'';width:20px;height:1px;background:var(--vi)}
.pg-title{font-family:'Syne',sans-serif;font-size:26px;font-weight:800;color:var(--t1);letter-spacing:-.04em;line-height:1.15;margin-bottom:8px}
.pg-title em{color:var(--gr);font-style:normal}
.pg-sub{font-size:13.5px;color:var(--t2);max-width:600px;line-height:1.7}

/* ── STATS ROW ── */
.stats-row{display:grid;grid-template-columns:repeat(6,1fr);gap:10px;margin-bottom:28px}
.stat{background:var(--c1);border:1px solid var(--br);border-radius:var(--r12);padding:14px;text-align:center;cursor:pointer;transition:all .15s}
.stat:hover{border-color:var(--vi);transform:translateY(-1px)}
.stat-n{font-family:'Syne',sans-serif;font-size:22px;font-weight:800;line-height:1}
.stat-l{font-size:10.5px;color:var(--t3);margin-top:4px;font-family:'JetBrains Mono',monospace}

/* ── TOOL CARDS ── */
.tool-grid{display:grid;gap:14px}
.grid-3{grid-template-columns:repeat(3,1fr)}
.grid-2{grid-template-columns:1fr 1fr}

.tool-card{background:var(--c1);border:1px solid var(--br);border-radius:var(--r16);overflow:hidden;transition:all .17s;position:relative}
.tool-card:hover{border-color:var(--br3);transform:translateY(-2px);box-shadow:0 8px 32px rgba(0,0,0,.4)}
.tool-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;opacity:.7}
.tool-card.vi::before{background:linear-gradient(90deg,var(--vi),var(--cy))}
.tool-card.gr::before{background:linear-gradient(90deg,var(--gr),var(--cy))}
.tool-card.am::before{background:linear-gradient(90deg,var(--am),var(--yw))}
.tool-card.cy::before{background:linear-gradient(90deg,var(--cy),var(--vi))}
.tool-card.re::before{background:linear-gradient(90deg,var(--re),var(--pk))}
.tool-card.pk::before{background:linear-gradient(90deg,var(--pk),var(--vi))}

.tc-header{padding:16px 18px 12px;display:flex;align-items:flex-start;gap:12px}
.tc-ico{width:44px;height:44px;border-radius:var(--r10);display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0}
.tc-ico.vi{background:var(--vix)}.tc-ico.gr{background:var(--grx)}.tc-ico.am{background:var(--amx)}.tc-ico.cy{background:var(--cyx)}.tc-ico.re{background:var(--rex)}.tc-ico.pk{background:var(--pkx)}.tc-ico.yw{background:var(--ywx)}
.tc-info{flex:1;min-width:0}
.tc-name{font-family:'Syne',sans-serif;font-size:14px;font-weight:700;color:var(--t1);margin-bottom:2px;letter-spacing:-.02em}
.tc-category{font-family:'JetBrains Mono',monospace;font-size:8.5px;color:var(--t3);letter-spacing:.1em;text-transform:uppercase;margin-bottom:5px}
.tc-desc{font-size:12px;color:var(--t2);line-height:1.6}
.tc-divider{height:1px;background:var(--br);margin:0 18px}
.tc-body{padding:12px 18px 16px;display:flex;flex-direction:column;gap:10px}

/* ── METRICS ROW ── */
.tc-metrics{display:flex;gap:12px}
.tc-metric{flex:1;background:var(--c2);border-radius:var(--r8);padding:8px 11px;text-align:center}
.tc-m-val{font-family:'Syne',sans-serif;font-size:16px;font-weight:700;line-height:1}
.tc-m-lbl{font-size:9.5px;color:var(--t3);margin-top:3px;font-family:'JetBrains Mono',monospace}

/* ── FEATURE LIST ── */
.tc-features{background:var(--c2);border-radius:var(--r8);padding:10px 12px}
.tc-feat-label{font-family:'JetBrains Mono',monospace;font-size:7.5px;letter-spacing:.16em;text-transform:uppercase;color:var(--t3);margin-bottom:7px}
.tc-feat-item{display:flex;align-items:flex-start;gap:7px;font-size:11.5px;color:var(--t2);margin-bottom:5px;line-height:1.45}
.tc-feat-item:last-child{margin:0}
.feat-dot{width:5px;height:5px;border-radius:50%;flex-shrink:0;margin-top:5px}

/* ── VIRAL / SEO SCORES ── */
.tc-scores{display:flex;gap:8px;flex-wrap:wrap}
.score-pill{display:inline-flex;align-items:center;gap:5px;padding:4px 10px;border-radius:20px;font-size:10px;font-weight:700}
.sp-vi{background:var(--vix);color:var(--vi);border:1px solid rgba(124,111,255,.2)}
.sp-gr{background:var(--grx);color:var(--gr);border:1px solid rgba(5,217,138,.2)}
.sp-am{background:var(--amx);color:var(--am);border:1px solid rgba(255,170,51,.2)}
.sp-cy{background:var(--cyx);color:var(--cy);border:1px solid rgba(0,220,255,.2)}
.sp-re{background:var(--rex);color:var(--re);border:1px solid rgba(255,77,106,.2)}
.sp-dim{background:var(--c3);color:var(--t3);border:1px solid var(--br)}

/* ── DEMO WIDGET ── */
.demo-widget{background:var(--bg);border:1px solid var(--br2);border-radius:var(--r10);padding:14px;margin-top:4px}
.demo-label{font-family:'JetBrains Mono',monospace;font-size:7.5px;letter-spacing:.16em;text-transform:uppercase;color:var(--vi);margin-bottom:10px;display:flex;align-items:center;gap:6px}
.demo-label::before{content:'▶';font-size:8px}

/* ── INPUTS ── */
.input-row{display:flex;gap:8px;align-items:center;margin-bottom:8px}
.demo-input{flex:1;padding:7px 10px;background:var(--c2);border:1px solid var(--br2);border-radius:var(--r8);font-family:'IBM Plex Sans',sans-serif;font-size:12.5px;color:var(--t1);outline:none;transition:border-color .14s}
.demo-input:focus{border-color:var(--vi)}
.demo-input::placeholder{color:var(--t3)}
.demo-input[type="range"]{padding:0;background:transparent;border:none;flex:1;accent-color:var(--vi);cursor:pointer;height:4px}
.range-val{font-family:'JetBrains Mono',monospace;font-size:11.5px;color:var(--vi);min-width:60px;text-align:right;font-weight:600}
.demo-select{padding:7px 10px;background:var(--c2);border:1px solid var(--br2);border-radius:var(--r8);font-family:'IBM Plex Sans',sans-serif;font-size:12.5px;color:var(--t1);outline:none;cursor:pointer}
.demo-label-text{font-size:11.5px;color:var(--t2);min-width:100px;flex-shrink:0}

/* ── RESULT DISPLAY ── */
.result-box{background:linear-gradient(135deg,var(--vix),var(--grx));border:1px solid rgba(124,111,255,.2);border-radius:var(--r10);padding:12px 14px;text-align:center;margin-top:8px}
.result-main{font-family:'Syne',sans-serif;font-size:22px;font-weight:800;color:var(--gr);line-height:1}
.result-sub{font-size:11px;color:var(--t2);margin-top:3px}
.result-row{display:flex;justify-content:space-between;padding:5px 0;border-bottom:1px solid rgba(255,255,255,.05);font-size:12px}
.result-row:last-child{border:none}
.result-lbl{color:var(--t3)}
.result-val{color:var(--t1);font-weight:600;font-family:'JetBrains Mono',monospace}

/* ── CHART ── */
.mini-bars{display:flex;align-items:flex-end;gap:3px;height:50px;margin-top:10px}
.bar{flex:1;border-radius:3px 3px 0 0;transition:height .4s ease;cursor:pointer;position:relative}
.bar:hover{filter:brightness(1.2)}
.bar-tip{position:absolute;top:-18px;left:50%;transform:translateX(-50%);font-size:8px;color:var(--t2);white-space:nowrap;font-family:'JetBrains Mono',monospace;opacity:0;transition:opacity .13s}
.bar:hover .bar-tip{opacity:1}

/* ── STRATEGY SECTION ── */
.strategy-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:24px}
.strat-card{background:var(--c1);border:1px solid var(--br);border-radius:var(--r12);padding:16px;transition:all .15s}
.strat-card:hover{border-color:var(--br3);transform:translateY(-1px)}
.strat-ico{font-size:24px;margin-bottom:9px}
.strat-title{font-family:'Syne',sans-serif;font-size:13px;font-weight:700;color:var(--t1);margin-bottom:4px}
.strat-desc{font-size:11.5px;color:var(--t3);line-height:1.6;margin-bottom:10px}
.strat-eg{font-size:10.5px;color:var(--vi);font-family:'JetBrains Mono',monospace}

/* ── TABLE ── */
.panel{background:var(--c1);border:1px solid var(--br);border-radius:var(--r12);overflow:hidden;margin-bottom:18px}
.panel-hd{padding:13px 16px;border-bottom:1px solid var(--br);display:flex;align-items:center;justify-content:space-between}
.panel-title{font-family:'Syne',sans-serif;font-size:13px;font-weight:700;color:var(--t1)}
table{width:100%;border-collapse:collapse}
thead th{padding:9px 14px;text-align:left;font-size:8px;letter-spacing:.14em;text-transform:uppercase;color:var(--t3);background:var(--c2);border-bottom:1px solid var(--br);font-family:'JetBrains Mono',monospace;font-weight:400}
thead th:first-child{padding-left:16px}
td{padding:11px 14px;border-bottom:1px solid var(--br);font-size:12.5px;vertical-align:middle}
td:first-child{padding-left:16px}
tbody tr:last-child td{border:none}
tbody tr:hover td{background:rgba(255,255,255,.015)}

/* ── NOTICE ── */
.notice{padding:11px 14px;border-radius:var(--r8);font-size:12.5px;line-height:1.65;margin-bottom:18px;display:flex;gap:10px}
.n-icon{font-size:14px;flex-shrink:0;margin-top:1px}
.notice.gr{background:var(--grx);border:1px solid rgba(5,217,138,.2);color:#80FFD0}
.notice.vi{background:var(--vix);border:1px solid rgba(124,111,255,.2);color:#C4BFFF}
.notice.am{background:var(--amx);border:1px solid rgba(255,170,51,.2);color:#FFCB80}

/* ── TABS ── */
.tabs{display:flex;gap:2px;background:var(--c2);border-radius:var(--r10);padding:3px;margin-bottom:22px}
.tab{padding:7px 16px;border-radius:var(--r8);font-size:12.5px;font-weight:600;cursor:pointer;color:var(--t3);transition:all .14s;user-select:none}
.tab:hover{color:var(--t2)}
.tab.active{background:var(--c1);color:var(--t1);box-shadow:0 1px 4px rgba(0,0,0,.3)}

/* ── RESPONSIVE ── */
@media(max-width:1100px){.grid-3{grid-template-columns:1fr 1fr}}
@media(max-width:800px){.sidebar{display:none}.main{margin-left:0}.stats-row{grid-template-columns:repeat(3,1fr)}.grid-3,.grid-2{grid-template-columns:1fr}.strategy-grid{grid-template-columns:1fr 1fr}}
</style>
</head>
<body>

<div class="app">

<!-- SIDEBAR -->
<aside class="sidebar" id="sb">
  <div class="sb-brand">
    <div class="sb-logo">Investing<em>Pro</em>.in</div>
    <div class="sb-tagline">Engineering as Marketing</div>
  </div>
  <div id="sb-nav"></div>
  <div class="sb-footer">
    <div class="sb-cta" onclick="showSection('overview')">View All 24 Tools →</div>
  </div>
</aside>

<!-- MAIN -->
<div class="main">
  <div class="topbar">
    <div class="tb-title" id="tb-title">Engineering as Marketing</div>
    <div class="tb-badges">
      <span class="tb-badge" style="background:var(--grx);color:var(--gr);border:1px solid rgba(5,217,138,.2)">24 Tools</span>
      <span class="tb-badge" style="background:var(--vix);color:var(--vi);border:1px solid rgba(124,111,255,.2)">5 Strategies</span>
      <span class="tb-badge" style="background:var(--amx);color:var(--am);border:1px solid rgba(255,170,51,.2)">3.2M+ Reach</span>
    </div>
  </div>
  <div class="content-area" id="content-root"></div>
</div>

</div><!-- .app -->

<script>
/* ── NAV STRUCTURE ── */
const NAV=[
  {id:'overview',ico:'⚡',label:'Overview',grp:'Home'},
  {id:'calculators',ico:'🧮',label:'Calculators',grp:'Tools',cnt:'8'},
  {id:'simulators',ico:'🎛',label:'Simulators',grp:'Tools',cnt:'5'},
  {id:'widgets',ico:'🔧',label:'Embeddable Widgets',grp:'Tools',cnt:'4'},
  {id:'data-tools',ico:'📊',label:'Data Visualizations',grp:'Tools',cnt:'4'},
  {id:'ai-tools',ico:'✦',label:'AI-Powered Tools',grp:'Tools',cnt:'3'},
  {id:'strategy',ico:'🗺',label:'Launch Strategy',grp:'Strategy'},
  {id:'virality',ico:'🚀',label:'Virality Mechanics',grp:'Strategy'},
];

let active='overview';

function buildNav(){
  const groups={};
  NAV.forEach(n=>{if(!groups[n.grp])groups[n.grp]=[];groups[n.grp].push(n);});
  let h='';
  for(const[g,items] of Object.entries(groups)){
    h+=`<div class="sb-sect">${g}</div>`;
    items.forEach(n=>{
      const badge=n.cnt?`<span class="sb-cnt">${n.cnt}</span>`:'';
      h+=`<div class="sb-item${active===n.id?' active':''}" onclick="showSection('${n.id}')"><span class="sb-item-ico">${n.ico}</span><span>${n.label}</span>${badge}</div>`;
    });
  }
  document.getElementById('sb-nav').innerHTML=h;
}

function showSection(id){
  active=id;
  const titles={overview:'Engineering as Marketing',calculators:'Calculators Hub',simulators:'Simulators',widgets:'Embeddable Widgets','data-tools':'Data Visualizations','ai-tools':'AI-Powered Tools',strategy:'Launch Strategy',virality:'Virality Mechanics'};
  document.getElementById('tb-title').textContent=titles[id]||id;
  buildNav();
  const pages={overview:pgOverview,calculators:pgCalculators,simulators:pgSimulators,widgets:pgWidgets,'data-tools':pgDataTools,'ai-tools':pgAITools,strategy:pgStrategy,virality:pgVirality};
  document.getElementById('content-root').innerHTML=(pages[id]||pgOverview)();
  initDemoWidgets();
}

/* ══════════════════════════════════
   DEMO WIDGET CALCULATORS
══════════════════════════════════ */
function initDemoWidgets(){
  // EMI Calculator
  calcEMI();
  // SIP Calculator
  calcSIP();
  // Tax Calculator
  calcTax();
  // CIBIL Simulator
  updateCIBIL();
  // FD Ladder
  calcFD();
  // Real Return Calculator
  calcRealReturn();
  // Credit Card Optimizer
  calcCard();
}

function fmt(n){return new Intl.NumberFormat('en-IN').format(Math.round(n));}
function cr(n){return '₹'+fmt(n);}

// EMI
function calcEMI(){
  const p=parseFloat(document.getElementById('emi-p')?.value)||5000000;
  const r=parseFloat(document.getElementById('emi-r')?.value)||8.5;
  const t=parseInt(document.getElementById('emi-t')?.value)||20;
  if(!document.getElementById('emi-result'))return;
  const mo=r/12/100, n=t*12;
  const emi=p*mo*Math.pow(1+mo,n)/(Math.pow(1+mo,n)-1);
  const total=emi*n, interest=total-p;
  document.getElementById('emi-result').innerHTML=`<div class="result-main">${cr(emi)}<span style="font-size:12px;color:var(--t2)">/mo</span></div><div class="result-sub">Monthly EMI</div>`;
  document.getElementById('emi-detail').innerHTML=`
    <div class="result-row"><span class="result-lbl">Principal</span><span class="result-val">${cr(p)}</span></div>
    <div class="result-row"><span class="result-lbl">Total Interest</span><span class="result-val" style="color:var(--re)">${cr(interest)}</span></div>
    <div class="result-row"><span class="result-lbl">Total Amount</span><span class="result-val">${cr(total)}</span></div>
    <div class="result-row"><span class="result-lbl">Interest to Principal</span><span class="result-val" style="color:var(--am)">${((interest/p)*100).toFixed(0)}%</span></div>`;
  document.getElementById('emi-rv')&&(document.getElementById('emi-rv').textContent=cr(p));
  document.getElementById('emi-rr')&&(document.getElementById('emi-rr').textContent=r+'%');
  document.getElementById('emi-rt')&&(document.getElementById('emi-rt').textContent=t+' yrs');
}

// SIP
function calcSIP(){
  const mo=parseFloat(document.getElementById('sip-mo')?.value)||10000;
  const r=parseFloat(document.getElementById('sip-r')?.value)||12;
  const y=parseInt(document.getElementById('sip-y')?.value)||15;
  if(!document.getElementById('sip-result'))return;
  const n=y*12, mr=r/12/100;
  const corpus=mo*(Math.pow(1+mr,n)-1)/mr*(1+mr);
  const invested=mo*n;
  const gains=corpus-invested;
  document.getElementById('sip-result').innerHTML=`<div class="result-main">${cr(corpus)}</div><div class="result-sub">Final Corpus</div>`;
  document.getElementById('sip-detail').innerHTML=`
    <div class="result-row"><span class="result-lbl">Total Invested</span><span class="result-val">${cr(invested)}</span></div>
    <div class="result-row"><span class="result-lbl">Returns Generated</span><span class="result-val" style="color:var(--gr)">${cr(gains)}</span></div>
