  const fuel=parseFloat(document.getElementById('cc-fuel')?.value)||5000;
  if(!document.getElementById('cc-result'))return;
  const total=online+travel+fuel;
  const cards=[
    {name:'SBI Cashback',fee:999,rewards:online*.05+total*.01,best:'Online'},
    {name:'HDFC Millennia',fee:1000,rewards:online*.05+travel*.025+total*.01,best:'Online+Travel'},
    {name:'Axis Ace',fee:499,rewards:total*.02+fuel*.05,best:'All-round+Fuel'},
    {name:'HDFC Regalia',fee:2500,rewards:(online+travel)*.04+fuel*.01,best:'Premium'},
  ];
  cards.forEach(c=>c.net=Math.max(0,c.rewards*12-c.fee));
