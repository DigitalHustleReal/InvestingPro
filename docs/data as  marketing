// Tax
function calcTax(){
  const inc=parseFloat(document.getElementById('tax-inc')?.value)||1200000;
  const ded=parseFloat(document.getElementById('tax-ded')?.value)||150000;
  if(!document.getElementById('tax-result'))return;
  // New regime FY26
  const newTax=(inc)=>{
    if(inc<=300000)return 0;
    if(inc<=700000)return (inc-300000)*.05;
    if(inc<=1000000)return 20000+(inc-700000)*.10;
    if(inc<=1200000)return 50000+(inc-1000000)*.15;
    if(inc<=1500000)return 80000+(inc-1200000)*.20;
    return 140000+(inc-1500000)*.30;
  };
  const oldTax=(inc)=>{
    if(inc<=250000)return 0;
    if(inc<=500000)return (inc-250000)*.05;
    if(inc<=1000000)return 12500+(inc-500000)*.20;
    return 112500+(inc-1000000)*.30;
  };
  const nt=newTax(inc)*1.04;
  const ot=oldTax(Math.max(0,inc-ded-50000))*1.04;
  const save=ot-nt;
  const better=save>0?'New Regime':'Old Regime';
  const saving=Math.abs(save);
  document.getElementById('tax-result').innerHTML=`
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:8px">
      <div style="background:var(--vix);border:1px solid rgba(124,111,255,.2);border-radius:8px;padding:10px;text-align:center">
        <div style="font-size:9px;font-family:JetBrains Mono,monospace;color:var(--vi);letter-spacing:.1em;margin-bottom:4px">NEW REGIME</div>
        <div style="font-family:Syne,sans-serif;font-size:18px;font-weight:800;color:var(--t1)">${cr(nt)}</div>
      </div>
      <div style="background:var(--amx);border:1px solid rgba(255,170,51,.2);border-radius:8px;padding:10px;text-align:center">
        <div style="font-size:9px;font-family:JetBrains Mono,monospace;color:var(--am);letter-spacing:.1em;margin-bottom:4px">OLD REGIME</div>
        <div style="font-family:Syne,sans-serif;font-size:18px;font-weight:800;color:var(--t1)">${cr(ot)}</div>
      </div>
    </div>
    <div style="background:var(--grx);border:1px solid rgba(5,217,138,.2);border-radius:8px;padding:10px;text-align:center">
      <div style="font-size:11px;color:var(--t2);margin-bottom:2px"><strong style="color:${save>0?'var(--gr)':'var(--am)'}">${better}</strong> saves you</div>
      <div style="font-family:Syne,sans-serif;font-size:22px;font-weight:800;color:var(--gr)">${cr(saving)}</div>
    </div>`;
  document.getElementById('tax-rv')&&(document.getElementById('tax-rv').textContent=cr(inc));
  document.getElementById('tax-rd')&&(document.getElementById('tax-rd').textContent=cr(ded));
}

// CIBIL Simulator
let baseScore=720, deltas={};
function toggleCIBIL(key,delta,el){
  if(deltas[key]!==undefined){delete deltas[key];el.style.background='';el.style.borderColor='';}
  else{deltas[key]=delta;el.style.background=delta>0?'rgba(5,217,138,.08)':'rgba(255,77,106,.08)';el.style.borderColor=delta>0?'rgba(5,217,138,.25)':'rgba(255,77,106,.25)';}
  updateCIBIL();
}
function updateCIBIL(){
  let s=baseScore;Object.values(deltas).forEach(d=>s+=d);
  s=Math.min(900,Math.max(300,s));
  const el=document.getElementById('cibil-score');const bar=document.getElementById('cibil-bar');const lbl=document.getElementById('cibil-label');
  if(!el)return;
  const pct=(s-300)/600*100;
  const color=s>=800?'var(--gr)':s>=700?'var(--vi)':s>=650?'var(--am)':'var(--re)';
  const label=s>=800?'Excellent':s>=750?'Very Good':s>=700?'Good':s>=650?'Fair':'Poor';
  el.textContent=s;el.style.color=color;
  bar.style.width=pct+'%';bar.style.background=color;
  lbl.textContent=label;lbl.style.color=color;
}

// FD Calculator
function calcFD(){
  const p=parseFloat(document.getElementById('fd-p')?.value)||100000;
  const r=parseFloat(document.getElementById('fd-r')?.value)||7.25;
  const y=parseInt(document.getElementById('fd-y')?.value)||3;
  const freq=parseInt(document.getElementById('fd-freq')?.value)||4;
  if(!document.getElementById('fd-result'))return;
  const maturity=p*Math.pow(1+r/(freq*100),freq*y);
  const gain=maturity-p;
  const taxable=gain*.30; // worst case
  document.getElementById('fd-result').innerHTML=`<div class="result-main">${cr(maturity)}</div><div class="result-sub">Maturity Amount</div>`;
  document.getElementById('fd-detail').innerHTML=`
