<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>InvestingPro — All Category Pages</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400;1,600&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{--ink:#1B2A4A;--saf:#E8871A;--safd:rgba(232,135,26,.1);--grn:#1A6B4A;--grn2:#4CAF7D;--grnd:rgba(26,107,74,.08);--cream:#F5F0E8;--paper:#FFFDF8;--mist:#E4DEDA;--ash:#7A8799;--red:#C0392B;--sky:#1E6FBF;--warn:#B45309;--pur:#6B21A8;}
*{box-sizing:border-box;margin:0;padding:0}html{scroll-behavior:smooth}
body{font-family:'DM Sans',system-ui,sans-serif;background:var(--cream);color:var(--ink);font-size:13.5px;line-height:1.65;-webkit-font-smoothing:antialiased}
.page{display:none}.page.on{display:block}

/* LEFT SIDEBAR NAVIGATOR */
.pnav{background:var(--paper);border-right:1px solid var(--mist);width:208px;position:fixed;top:0;left:0;bottom:0;overflow-y:auto;z-index:500;scrollbar-width:thin}
.pn-logo{font-family:'Playfair Display',serif;font-size:16px;font-style:italic;color:var(--ink);padding:14px 16px 12px;border-bottom:1px solid var(--mist);display:block;cursor:pointer}
.pn-logo em{color:var(--saf)}
.pn-sec{font-size:9px;letter-spacing:.12em;text-transform:uppercase;font-weight:700;color:var(--ash);padding:12px 16px 5px}
.pnl{display:flex;align-items:center;gap:7px;padding:9px 16px;font-size:12.5px;color:var(--ash);cursor:pointer;transition:all .12s;border-left:2px solid transparent;font-weight:500}
.pnl:hover{background:var(--cream);color:var(--ink)}.pnl.on{color:var(--ink);border-left-color:var(--saf);background:var(--safd);font-weight:600}
.pnl .ic{font-size:14px;width:20px;text-align:center}

/* MAIN CONTENT */
.ca{margin-left:208px}
@media(max-width:800px){.pnav{transform:translateX(-100%);transition:transform .25s;z-index:600}.pnav.open{transform:translateX(0);box-shadow:4px 0 20px rgba(27,42,74,.15)}.ca{margin-left:0}}

/* SHARED NAV */
.topnav{background:var(--paper);height:54px;display:flex;align-items:stretch;padding:0 20px;border-bottom:1px solid var(--mist);position:sticky;top:0;z-index:300}
.logo{font-family:'Playfair Display',serif;font-size:18px;font-style:italic;color:var(--ink);display:flex;align-items:center;margin-right:16px;flex-shrink:0;cursor:pointer}
.logo em{color:var(--saf)}
.navlinks{display:flex;height:54px;overflow-x:auto;scrollbar-width:none;flex:1}
.navlinks::-webkit-scrollbar{display:none}
.nl{height:54px;padding:0 11px;display:flex;align-items:center;font-size:12.5px;font-weight:500;color:var(--ash);cursor:pointer;border:none;background:none;border-bottom:2px solid transparent;white-space:nowrap;transition:all .13s;font-family:inherit}
.nl:hover,.nl.on{color:var(--ink);border-bottom-color:var(--saf)}.nl.grn{color:var(--grn);font-weight:600}
.navr{margin-left:auto;display:flex;align-items:center;gap:7px;flex-shrink:0}
.btnp{padding:7px 13px;background:var(--saf);color:#fff;border:none;border-radius:6px;font-family:inherit;font-size:12px;font-weight:600;cursor:pointer}.btnp:hover{background:#D4791A}
.ham{display:none;flex-direction:column;gap:4px;background:none;border:none;cursor:pointer;padding:4px}
.ham span{width:18px;height:1.5px;background:var(--ash);display:block;border-radius:1px}
@media(max-width:800px){.navlinks,.navr .btnp{display:none}.ham{display:flex}}

/* TRUST BAR */
.tbar{background:var(--grn);padding:6px 20px;display:flex;gap:0;overflow-x:auto;scrollbar-width:none}
.tbar::-webkit-scrollbar{display:none}
.ti{display:flex;align-items:center;gap:5px;font-size:11px;color:rgba(245,240,232,.8);padding:0 12px;border-right:1px solid rgba(245,240,232,.15);white-space:nowrap;font-weight:500}
.ti:first-child{padding-left:0}.ti:last-child{border:none}.ti::before{content:'✓';font-size:10px}

/* BREADCRUMB */
.bc{background:var(--paper);border-bottom:1px solid var(--mist);padding:8px 20px;font-size:12px;color:var(--ash)}
.bc a{color:var(--saf);text-decoration:none;cursor:pointer}.bc .cur{color:var(--ink);font-weight:500}

/* PAGE HEADER */
.ph{background:var(--paper);padding:20px;border-bottom:1px solid var(--mist)}
.ph h1{font-family:'Playfair Display',serif;font-size:24px;font-style:italic;font-weight:400;color:var(--ink);margin-bottom:5px}
.ph h1 em{color:var(--saf)}
.kicker{font-size:9px;letter-spacing:.15em;text-transform:uppercase;font-weight:700;color:var(--saf);margin-bottom:5px}
.ph-meta{font-size:12px;color:var(--ash);display:flex;gap:12px;flex-wrap:wrap}

/* 2-COL LAYOUT */
.pb{display:grid;grid-template-columns:1fr 258px;gap:0;max-width:1020px;margin:0 auto;padding:18px 20px;align-items:start}
@media(max-width:700px){.pb{grid-template-columns:1fr;padding:14px 14px}}
.mc{}.sb{padding-left:17px}
@media(max-width:700px){.sb{padding-left:0;margin-top:18px}}

/* EDITORIAL NOTE */
.en{background:var(--grnd);border:1px solid rgba(26,107,74,.15);border-radius:10px;padding:12px 14px;display:flex;gap:9px;align-items:flex-start;margin-bottom:14px}
.en-ic{width:22px;height:22px;border-radius:50%;background:var(--grn);display:flex;align-items:center;justify-content:center;font-size:10px;color:#fff;flex-shrink:0;font-weight:700}
.en-tg{font-size:9px;letter-spacing:.08em;text-transform:uppercase;font-weight:700;color:var(--grn);margin-bottom:2px}
.en-bd{font-size:12px;color:#1A3D2B;line-height:1.6}

/* METHOD STRIP */
.ms{background:rgba(26,107,74,.04);border-top:1px solid rgba(26,107,74,.1);border-bottom:1px solid rgba(26,107,74,.1);padding:7px 20px;font-size:12px;color:#1A3D2B;display:flex;align-items:center;gap:7px;flex-wrap:wrap}
.ms a{color:var(--sky);text-decoration:none;font-weight:500}
.msc{padding:2px 7px;border-radius:6px;font-size:10.5px;font-weight:700;background:#E8F5EE;color:var(--grn);white-space:nowrap}

/* FILTER BAR */
.fb{background:var(--paper);border-bottom:1px solid var(--mist);padding:8px 20px;display:flex;gap:6px;align-items:center;flex-wrap:wrap}
.fbl{font-size:9.5px;letter-spacing:.1em;text-transform:uppercase;font-weight:700;color:var(--ash);flex-shrink:0}
.chip{padding:5px 11px;border:1px solid var(--mist);border-radius:20px;font-size:12px;color:var(--ash);background:var(--paper);cursor:pointer;white-space:nowrap;transition:all .12s;font-family:inherit}
.chip:hover{border-color:var(--saf);color:var(--saf)}.chip.on{background:var(--saf);border-color:var(--saf);color:#fff}
.fbr{margin-left:auto;font-size:12px;color:var(--sky);cursor:pointer;font-weight:500;white-space:nowrap}

/* CARD ROW */
.cr{background:var(--paper);border:1px solid var(--mist);border-radius:12px;overflow:hidden;margin-bottom:9px;transition:border-color .15s,box-shadow .15s}
.cr:hover{border-color:rgba(232,135,26,.3);box-shadow:0 3px 14px rgba(27,42,74,.05)}
.crpk{background:var(--safd);padding:4px 15px;font-size:9px;letter-spacing:.06em;text-transform:uppercase;color:var(--saf);font-weight:700;border-bottom:1px solid rgba(232,135,26,.1)}
.cri{display:grid;grid-template-columns:96px 1fr 112px;align-items:stretch}
@media(max-width:550px){.cri{grid-template-columns:78px 1fr}.crr{display:none}}
.crl{padding:12px 9px;display:flex;flex-direction:column;align-items:center;gap:5px;border-right:1px solid var(--mist)}
.ct{width:64px;height:40px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:#fff;font-family:'DM Mono',monospace;letter-spacing:.04em}
.crbn{font-size:9.5px;color:var(--ash);text-align:center}
.sts{font-size:10px;color:#F59E0B;letter-spacing:-1px}
.crm{padding:12px 15px}
.crn{font-size:13.5px;font-weight:600;color:var(--ink);margin-bottom:3px}
.crd{font-size:12px;color:var(--ash);margin-bottom:7px;line-height:1.5}
.crtags{display:flex;flex-wrap:wrap;gap:4px;margin-bottom:7px}
.tg{padding:3px 7px;border-radius:5px;font-size:11px;font-weight:500}
.tgg{background:#EBF7F0;color:var(--grn)}.tgr{background:#FDECEA;color:var(--red)}.tgb{background:#EAF2FB;color:var(--sky)}.tgm{background:var(--cream);color:var(--ash)}
.crst{display:flex;gap:13px}
.csi .v{font-size:12.5px;font-weight:600;color:var(--ink)}.csi .l{font-size:10px;color:var(--ash);margin-top:1px}
.crr{padding:11px 9px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:7px;border-left:1px solid var(--mist)}
.ring{position:relative;width:48px;height:48px}
.ring svg{width:48px;height:48px;transform:rotate(-90deg)}
.ringc{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;line-height:1.1}
.rp{font-size:11px;font-weight:700}.rl{font-size:8px;color:var(--ash)}
.bap{width:100%;padding:7px;background:var(--saf);color:#fff;border:none;border-radius:5px;font-family:inherit;font-size:11.5px;font-weight:700;cursor:pointer}.bap:hover{background:#D4791A}
.bcp{width:100%;padding:6px;background:transparent;color:var(--ash);border:1px solid var(--mist);border-radius:5px;font-family:inherit;font-size:11px;cursor:pointer}.bcp:hover{border-color:var(--ink);color:var(--ink)}
.crf{padding:6px 15px;background:var(--cream);border-top:1px solid var(--mist);display:flex;justify-content:space-between;font-size:11px;color:var(--ash)}
.crf .ed{color:var(--grn);font-weight:500}.crf a{color:var(--sky);text-decoration:none}

/* SIDEBAR */
.sc{background:var(--paper);border:1px solid var(--mist);border-radius:11px;padding:14px;margin-bottom:13px}
.sk{font-size:9px;letter-spacing:.1em;text-transform:uppercase;font-weight:700;color:var(--ash);margin-bottom:9px}
.slink{display:flex;align-items:center;gap:6px;padding:5px 6px;border-radius:6px;cursor:pointer;text-decoration:none;transition:background .12s;font-size:12.5px;color:var(--sky);margin-bottom:1px}
.slink:hover{background:var(--cream)}.slink::before{content:'›';color:var(--saf);font-size:12px}
.rr{display:flex;justify-content:space-between;align-items:center;padding:5px 0;border-bottom:1px solid var(--mist);font-size:12px}
.rr:last-child{border:none}.rb{color:var(--ash)}.rv{font-weight:700;color:var(--grn)}
.toc-l{display:flex;align-items:center;gap:6px;padding:5px 6px;border-radius:6px;cursor:pointer;transition:background .12s;font-size:12.5px;color:var(--ink);border-bottom:1px solid var(--mist);margin-bottom:0}
.toc-l:last-child{border:none}.toc-l:hover{background:var(--cream)}.toc-l::before{content:'§';color:var(--saf);font-size:10px}

/* CALCULATOR */
.cw{background:var(--paper);border:1px solid var(--mist);border-radius:11px;overflow:hidden;margin-bottom:14px}
.ci2{display:grid;grid-template-columns:310px 1fr}
@media(max-width:650px){.ci2{grid-template-columns:1fr}}
.cin{padding:18px;border-right:1px solid var(--mist)}.cout{padding:18px;background:var(--cream)}
.fl{font-size:12px;font-weight:600;color:var(--ink);margin-bottom:5px;display:block}
.fh{font-size:11px;color:var(--ash);margin-top:2px}
.slr{display:flex;justify-content:space-between;font-size:11px;color:var(--ash);margin-bottom:2px}.slv{font-weight:600;color:var(--ink)}
input[type=range]{width:100%;accent-color:var(--saf);margin:2px 0}
.ip{width:100%;border:1px solid var(--mist);border-radius:6px;padding:8px 11px;font-family:inherit;font-size:12.5px;color:var(--ink);background:var(--paper);outline:none;transition:border-color .13s}
.ip:focus{border-color:var(--saf)}.ip.sel{cursor:pointer}
.ctab{width:100%;padding:10px;background:var(--saf);color:#fff;border:none;border-radius:7px;font-family:inherit;font-size:13px;font-weight:700;cursor:pointer;margin-top:4px}.ctab:hover{background:#D4791A}
.ctag{background:var(--grn)}.ctag:hover{background:#155d3e}
.rg{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px}
.rc2{background:var(--paper);border:1px solid var(--mist);border-radius:8px;padding:11px;text-align:center}
.rc2.hero{background:var(--ink);grid-column:span 2}
.rnum{font-family:'Playfair Display',serif;font-size:20px;color:var(--ink)}
.rc2.hero .rnum{color:var(--saf);font-size:24px}
.rlb{font-size:10px;color:var(--ash);margin-top:2px;text-transform:uppercase;letter-spacing:.06em}
.rc2.hero .rlb{color:rgba(245,240,232,.4)}
.pr{display:flex;align-items:center;gap:7px;margin-bottom:5px}
.plb{font-size:11.5px;color:var(--ash);width:100px;flex-shrink:0}
.pt{flex:1;height:6px;background:var(--mist);border-radius:3px;overflow:hidden}
.pf{height:100%;border-radius:3px}.pvl{font-size:11.5px;font-weight:600;width:32px;text-align:right;flex-shrink:0}
.comp-r{display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid var(--mist);font-size:12px}
.comp-r:last-child{border:none}.compb{color:var(--ash)}.compv{font-weight:600}

/* SECTION HEADING */
.sh{margin:20px 0 12px}
.sh h2{font-family:'Playfair Display',serif;font-size:18px;font-style:italic;color:var(--ink);font-weight:400}
.sh h2 em{color:var(--saf)}.sh p{font-size:12.5px;color:var(--ash);margin-top:3px}

/* DATA TABLE */
.dt{width:100%;border-collapse:collapse;margin-bottom:14px;border-radius:10px;overflow:hidden;border:1px solid var(--mist)}
.dt th{background:var(--ink);color:rgba(245,240,232,.7);padding:8px 12px;text-align:left;font-size:10.5px;font-weight:600;letter-spacing:.06em;text-transform:uppercase}
.dt th:last-child{text-align:right}
.dt td{padding:9px 12px;border-bottom:1px solid var(--mist);font-size:12.5px}
.dt tr:last-child td{border:none}.dt tr:hover td{background:rgba(232,135,26,.02)}.dt td:last-child{text-align:right}
.dg{color:var(--grn);font-weight:700}.dr{color:var(--red)}.dw{color:var(--warn)}
.dtag{font-size:10.5px;font-weight:700;padding:2px 7px;border-radius:6px}
.dtag-g{background:#E8F5EE;color:var(--grn)}.dtag-b{background:#EAF2FB;color:var(--sky)}

/* FUND ROW */
.fr{background:var(--paper);border:1px solid var(--mist);border-radius:10px;overflow:hidden;margin-bottom:7px;display:grid;grid-template-columns:1fr auto;align-items:center;transition:border-color .14s}
.fr:hover{border-color:rgba(232,135,26,.25)}
.frm{padding:12px 15px}.frn{font-size:13px;font-weight:600;color:var(--ink);margin-bottom:3px}
.frt{display:flex;gap:4px;margin-bottom:5px}
.frs{display:flex;gap:14px}.frs .v{font-size:13.5px;font-weight:700}.frs .l{font-size:10px;color:var(--ash);margin-top:1px}
.frc{padding:0 13px;display:flex;flex-direction:column;gap:6px;border-left:1px solid var(--mist)}
@media(max-width:550px){.fr{grid-template-columns:1fr}.frc{flex-direction:row;border-left:none;border-top:1px solid var(--mist);padding:9px 15px}}
.bsip{padding:7px 12px;background:var(--pur);color:#fff;border:none;border-radius:5px;font-family:inherit;font-size:11.5px;font-weight:700;cursor:pointer;white-space:nowrap}
.blump{padding:7px 12px;background:transparent;color:var(--ash);border:1px solid var(--mist);border-radius:5px;font-family:inherit;font-size:11.5px;cursor:pointer}.blump:hover{border-color:var(--ink);color:var(--ink)}

/* INSURANCE CARD */
.ic{background:var(--paper);border:1px solid var(--mist);border-radius:11px;overflow:hidden;transition:border-color .14s}
.ic:hover{border-color:rgba(232,135,26,.25)}
.ich{padding:12px 14px;border-bottom:1px solid var(--mist)}
.icn{font-size:13.5px;font-weight:600;color:var(--ink);margin-bottom:2px}.icc{font-size:11px;color:var(--ash)}
.icb{padding:12px 14px}
.icp{font-family:'Playfair Display',serif;font-size:21px;color:var(--ink)}.icpl{font-size:10px;color:var(--ash);margin-bottom:7px}
.icfeats{display:flex;flex-direction:column;gap:3px}
.icfeats span{display:flex;align-items:center;gap:5px;font-size:11.5px;color:var(--ash)}
.icfeats span::before{content:'✓';color:var(--grn);font-size:11px}
.icft{padding:9px 14px;background:var(--cream);border-top:1px solid var(--mist);display:flex;gap:6px}
.ib{flex:1;padding:7px;background:var(--saf);color:#fff;border:none;border-radius:5px;font-family:inherit;font-size:11.5px;font-weight:700;cursor:pointer}

/* FD RATE CARD */
.fdc{background:var(--paper);border:1px solid var(--mist);border-radius:11px;overflow:hidden;margin-bottom:11px}
.fdch{padding:11px 14px;border-bottom:1px solid var(--mist);display:flex;justify-content:space-between;align-items:center}
.fdcn{font-size:13px;font-weight:600;color:var(--ink)}
.fdtg{padding:2px 8px;border-radius:6px;font-size:10px;font-weight:700}
.fdtg-g{background:#E8F5EE;color:var(--grn)}.fdtg-b{background:#EAF2FB;color:var(--sky)}.fdtg-m{background:var(--cream);color:var(--ash)}
.fdt{width:100%;border-collapse:collapse}
.fdt th{background:var(--cream);padding:7px 12px;font-size:10px;font-weight:700;color:var(--ash);text-transform:uppercase;letter-spacing:.05em;text-align:left}
.fdt th:last-child{text-align:right}
.fdt td{padding:8px 12px;border-bottom:1px solid var(--mist);font-size:12.5px}
.fdt tr:last-child td{border:none}.fdt td:last-child{text-align:right;font-weight:700}.fdb{color:var(--grn)}

/* TAX / REGIME */
.reg{border-radius:10px;overflow:hidden;border:1px solid var(--mist)}
.regh{padding:11px 14px;border-bottom:1px solid var(--mist)}
.regn{font-size:13.5px;font-weight:600;margin-bottom:2px}.regsub{font-size:11px;color:var(--ash)}
.regrow{display:flex;justify-content:space-between;padding:7px 14px;border-bottom:1px solid var(--mist);font-size:12px}
.regrow:last-child{border:none}.rrl{color:var(--ash)}.rrv{font-weight:600}
.regres{padding:11px 14px;text-align:center;border-top:2px solid var(--mist)}
.rrtax{font-family:'Playfair Display',serif;font-size:21px;font-weight:400}.rrlb{font-size:10.5px;color:var(--ash);margin-top:2px}

/* CIBIL HERO */
.cibhero{background:var(--ink);padding:28px 20px;position:relative;overflow:hidden}
.cibhero::before{content:'';position:absolute;right:-50px;top:-50px;width:280px;height:280px;background:radial-gradient(circle,rgba(232,135,26,.07) 0%,transparent 65%);pointer-events:none}
.cibhero-inner{max-width:980px;margin:0 auto;display:grid;grid-template-columns:1fr 360px;gap:28px;align-items:start;position:relative;z-index:1}
@media(max-width:700px){.cibhero-inner{grid-template-columns:1fr}}
.sb-bands{display:grid;grid-template-columns:repeat(5,1fr);gap:5px;margin:14px 0}
.sbb{border-radius:7px;padding:9px 6px;text-align:center}
.sbb-n{font-family:'Playfair Display',serif;font-size:14px;margin-bottom:2px}
.sbb-l{font-size:9px;font-weight:600;text-transform:uppercase;letter-spacing:.05em}.sbb-r{font-size:9px;margin-top:2px;opacity:.7}
.fb2r{display:flex;align-items:center;gap:7px;margin-bottom:4px}
.fb2l{font-size:11px;color:rgba(245,240,232,.6);width:120px;flex-shrink:0}
.fb2t{flex:1;height:5px;background:rgba(255,255,255,.1);border-radius:3px;overflow:hidden}
.fb2f{height:100%;border-radius:3px}.fb2v{font-size:11px;font-weight:600;width:40px;text-align:right;flex-shrink:0;color:rgba(245,240,232,.55)}
.simcard{background:rgba(245,240,232,.06);border:1px solid rgba(245,240,232,.12);border-radius:13px;padding:18px}
.bigring{position:relative;width:130px;height:130px;margin:0 auto 14px}
.bigring svg{width:130px;height:130px;transform:rotate(-90deg)}
.brc{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center}
.brn{font-family:'Playfair Display',serif;font-size:34px;color:var(--grn2);line-height:1}.brl{font-size:11px;color:rgba(245,240,232,.4);margin-top:2px}
.sima{background:var(--cream);border:1px solid var(--mist);border-radius:7px;padding:9px 11px;margin-bottom:5px;display:flex;justify-content:space-between;align-items:center;cursor:pointer;transition:background .12s}
.sima:hover{background:#E0D9D0}
.sat{font-size:12px;font-weight:500;color:var(--ink)}.sas{font-size:11px;color:var(--ash);margin-top:1px}
.dp{background:#E8F5EE;color:var(--grn);padding:2px 7px;border-radius:6px;font-size:11.5px;font-weight:700;flex-shrink:0}
