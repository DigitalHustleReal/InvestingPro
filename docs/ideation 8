/* ─── HELPERS ─── */
function ss(id,val){const el=document.getElementById(id);if(el)el.textContent=val}
function sst(id,prop,val){const el=document.getElementById(id);if(el)el.style[prop]=val}
function fmt(n){return Math.round(n).toLocaleString('en-IN')}
function fmtL(n){n=Math.round(n);if(n>=10000000)return(n/10000000).toFixed(1)+'Cr';if(n>=100000)return(n/100000).toFixed(1)+'L';return n.toLocaleString('en-IN')}

