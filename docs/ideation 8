/* ─── CIBIL SIMULATOR ─── */
let cBase=748,cD={};
function cibSim(el,delta){
  const k=el.querySelector('.sat').textContent.slice(0,20);
  if(cD[k]){delete cD[k];el.style.background='';el.style.borderColor=''}
  else{cD[k]=delta;el.style.background=delta>0?'rgba(26,107,74,.07)':'rgba(192,57,43,.07)';el.style.borderColor=delta>0?'rgba(26,107,74,.2)':'rgba(192,57,43,.2)'}
  let s=cBase;Object.values(cD).forEach(x=>s+=x);
  s=Math.min(900,Math.max(300,s));
  const el2=document.getElementById('cib-n');if(el2)el2.textContent=s;
  const l=s>=800?'Excellent':s>=750?'Very Good':s>=700?'Good':s>=650?'Fair':'Poor';
  const c=s>=700?'#4CAF7D':s>=650?'#FBB040':'#F87171';
  const ll=document.getElementById('cib-l');if(ll)ll.textContent=l;
  if(el2)el2.style.color=c;
  const ring=document.getElementById('cib-ring');
  if(ring){const dash=Math.round(((s-300)/600)*327);ring.setAttribute('stroke-dasharray',dash+' 327');ring.setAttribute('stroke',c);}
}

/* ─── EMI CALCULATOR ─── */
function cEMI(){
  const P=+(document.getElementById('ea')||{value:6000000}).value;
  const cibP=+(document.getElementById('ecibil')||{value:0.5}).value;
  const baseR=+(document.getElementById('er')||{value:8.35}).value;
  const actualR=baseR+cibP;
  const n=+(document.getElementById('et')||{value:20}).value*12;
  const r=actualR/(12*100);
  const emi=r===0?P/n:P*r*Math.pow(1+r,n)/(Math.pow(1+r,n)-1);
  const tot=emi*n;const interest=tot-P;
  const pPct=Math.round(P/tot*100);const iPct=100-pPct;
  ss('ea-v','₹'+fmt(P));ss('er-v',baseR.toFixed(2)+'%');ss('et-v',Math.round(n/12)+' years');
  ss('e-emi',Math.round(emi).toLocaleString('en-IN'));
  ss('e-int','₹'+fmtL(interest));ss('e-tot','₹'+fmtL(tot));
  sst('e-pbar','width',pPct+'%');sst('e-ibar','width',iPct+'%');
  ss('e-pp',pPct+'%');ss('e-ip',iPct+'%');
  const sbr=(8.35+cibP)/(12*100);const sEMI=P*sbr*Math.pow(1+sbr,n)/(Math.pow(1+sbr,n)-1);
  const hbr=(8.5+cibP)/(12*100);const hEMI=P*hbr*Math.pow(1+hbr,n)/(Math.pow(1+hbr,n)-1);
  ss('e-sbi','₹'+Math.round(sEMI).toLocaleString('en-IN'));
  ss('e-hdfc','₹'+Math.round(hEMI).toLocaleString('en-IN'));
  ss('e-your','₹'+Math.round(emi).toLocaleString('en-IN'));
  const bestEMI=P*(8.35/(12*100))*Math.pow(1+8.35/(12*100),n)/(Math.pow(1+8.35/(12*100),n)-1);
  ss('e-save','₹'+fmtL(Math.abs((emi-bestEMI)*n))+' over '+Math.round(n/12)+'yr');
  const ar=document.getElementById('e-ar');if(ar)ar.textContent=actualR.toFixed(2)+'%';
  const arbox=document.getElementById('e-actualrate');if(arbox)arbox.querySelector('strong').textContent=actualR.toFixed(2)+'%';
}

/* ─── SIP CALCULATOR ─── */
function cSIP(){
  const sip=+(document.getElementById('sa')||{value:5000}).value;
  const r=+(document.getElementById('sr')||{value:12}).value/100/12;
  const n=+(document.getElementById('sy')||{value:10}).value*12;
  const step=+(document.getElementById('ss')||{value:10}).value/100;
  ss('sa-v','₹'+sip.toLocaleString('en-IN'));
  ss('sr-v',(document.getElementById('sr')||{value:12}).value+'%');
  ss('sy-v',Math.round(n/12)+' years');
  ss('ss-v',(document.getElementById('ss')||{value:10}).value+'%');
  const inv=sip*n;
  const fv=r===0?inv:sip*((Math.pow(1+r,n)-1)/r)*(1+r);
  const gains=fv-inv;const invP=Math.round(inv/fv*100);
  ss('s-corp',fmtL(fv));ss('s-inv','₹'+fmtL(inv));ss('s-gain','₹'+fmtL(gains));
  sst('s-ibar','width',invP+'%');sst('s-gbar','width',(100-invP)+'%');
  ss('s-ipp',invP+'%');ss('s-gpp',(100-invP)+'%');
  ss('s-ns','₹'+fmtL(fv));
  let stepFV=0;let m=sip;
  for(let y=0;y<Math.round(n/12);y++){for(let mo=0;mo<12;mo++)stepFV=(stepFV+m)*(1+r);m*=(1+step);}
  ss('s-ws','₹'+fmtL(stepFV));ss('s-diff','₹'+fmtL(Math.abs(stepFV-fv))+' more');
}

/* ─── FD CALCULATOR ─── */
let fdA=100000,fdR=7.25,fdT=2;
function cFD(type,val){
  if(type==='a'){fdA=+val;ss('fda-v','₹'+fmt(fdA))}
  if(type==='r'){fdR=+val;ss('fdr-v',fdR+'%')}
  if(type==='t'){fdT=+val;ss('fdt-v',fdT+' year'+(fdT>1?'s':''))}
  const mat=fdA*Math.pow(1+fdR/100,fdT);
  const int=mat-fdA;
  ss('fd-mat','₹'+Math.round(mat).toLocaleString('en-IN'));
  ss('fd-int','Earned: ₹'+Math.round(int).toLocaleString('en-IN'));
}

/* ─── TAX CALCULATOR ─── */
function cTax(){
  const inc=+(document.getElementById('ti')||{value:1200000}).value;
  const hra=+(document.getElementById('th')||{value:150000}).value;
  const c80=+(document.getElementById('tc')||{value:150000}).value;
  const hl=+(document.getElementById('tl')||{value:150000}).value;
  ss('ti-v','₹'+fmtL(inc));ss('th-v','₹'+fmtL(hra));ss('tc-v','₹'+fmtL(c80));ss('tl-v','₹'+fmtL(hl));
  const oldDed=50000+hra+c80+hl;const oldTI=Math.max(0,inc-oldDed);const oldTax=calcOld(oldTI);
  const newTI=Math.max(0,inc-75000);const newTax=calcNew(newTI);
  ss('to-g','₹'+fmtL(inc));ss('to-d','−₹'+fmtL(oldDed));ss('to-t','₹'+fmtL(oldTI));ss('to-tax','₹'+fmtL(oldTax));
  ss('tn-g','₹'+fmtL(inc));ss('tn-t','₹'+fmtL(newTI));ss('tn-tax','₹'+fmtL(newTax));
  const diff=newTax-oldTax;
  ss('t-rec',diff>0?'Old regime saves you ₹'+fmtL(diff)+' more':diff<0?'New regime saves you ₹'+fmtL(-diff)+' more':'Both regimes equal for you');
}
function calcOld(inc){let t=0;if(inc>1000000)t+=(inc-1000000)*.3;if(inc>500000)t+=Math.min(inc-500000,500000)*.2;if(inc>250000)t+=Math.min(inc-250000,250000)*.05;return Math.round(t*1.04)}
function calcNew(inc){if(inc<=700000)return 0;let t=0;const sl=[[300000,0],[400000,.05],[300000,.1],[400000,.15],[300000,.2],[Infinity,.3]];let rem=inc;for(const[lim,rt]of sl){const ch=Math.min(rem,lim);t+=ch*rt;rem-=ch;if(rem<=0)break}return Math.round(t*1.04)}

