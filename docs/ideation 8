function buildGlossary(){
  const alpha='ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('');
  const ac=document.getElementById('gal-alpha');
  if(!ac)return;
  alpha.forEach(l=>{
    const b=document.createElement('button');
    b.className='gab';b.textContent=l;
    b.onclick=()=>{document.querySelectorAll('.gab').forEach(x=>x.classList.remove('on'));b.classList.add('on');renderGlos(GLOS.filter(t=>t.t[0].toUpperCase()===l))};
    ac.appendChild(b);
  });
  renderGlos(GLOS);
}
function renderGlos(terms){
  const g=document.getElementById('glos-grid');
  if(!g)return;
  g.innerHTML='';
  terms.forEach(t=>{
    const d=document.createElement('div');d.className='gi';
    d.innerHTML=`<div><div class="git">${t.t}</div><div class="gis">${t.s}</div></div><span class="gia">›</span>`;
    d.onclick=()=>{
      document.getElementById('gd-t').textContent=t.t;
      document.getElementById('gd-b').innerHTML=`<p>${t.def}</p><div class="gdex">📐 <strong>Example:</strong> ${t.ex}</div>`;
      const rel=document.getElementById('gd-rel');rel.innerHTML='';
      t.rel.forEach(r=>{const s=document.createElement('span');s.className='rtl';s.textContent=r;s.onclick=()=>{const found=GLOS.find(x=>x.t===r);if(found)d.onclick()};rel.appendChild(s)});
      document.getElementById('glos-det').style.display='block';
      document.getElementById('glos-det').scrollIntoView({behavior:'smooth',block:'start'});
    };
    g.appendChild(d);
  });
}
function searchGlos(){
  const q=(document.getElementById('glos-q').value||'').toLowerCase();
  renderGlos(q?GLOS.filter(t=>t.t.toLowerCase().includes(q)||t.s.toLowerCase().includes(q)||t.def.toLowerCase().includes(q)):GLOS);
}

