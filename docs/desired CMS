/* ═══════════ MODAL ═══════════ */
function modal(html,size='600px'){
  const r=document.getElementById('modal-root');
  r.innerHTML=`<div class="modal-overlay" onclick="if(event.target===this)closeModal()"><div class="modal" style="max-width:${size}">${html}</div></div>`;
}
function closeModal(){document.getElementById('modal-root').innerHTML='';}
function closeAndRefresh(){closeModal();go(S.page);}

/* ═══════════ TOAST ═══════════ */
function toast(msg,type='info'){
  const d=document.createElement('div');
  d.className=`toast ${type}`;
  const icons={success:'✓',error:'✕',info:'✦',warn:'⚠'};
  d.innerHTML=`<span class="toast-icon">${icons[type]||'✦'}</span>${msg}`;
  document.getElementById('toast-root').appendChild(d);
  setTimeout(()=>d.style.opacity='0',2800);
  setTimeout(()=>d.remove(),3200);
}

/* ═══════════ HELPERS ═══════════ */
function timeAgo(ts){const m=Math.round((Date.now()-ts)/60000);return m<2?'just now':m<60?m+'m ago':m<1440?Math.round(m/60)+'h ago':Math.round(m/1440)+'d ago';}
function scoreColor(n){return n>80?'var(--gr)':n>60?'var(--am)':'var(--re)';}
function scoreClass(n){return n>80?'score-hi':n>60?'score-md':'score-lo';}
function statusBadge(s){const m={published:'b-gr',draft:'b-dim',review:'b-am',archived:'b-re'};return`<span class="badge ${m[s]||'b-dim'}">${s}</span>`;}
function pagStatus(s){const m={target:'b-am',page2:'b-cy',top10:'b-vi',top5:'b-gr',ranking:'b-gr'};return`<span class="badge ${m[s]||'b-dim'}">${s}</span>`;}

