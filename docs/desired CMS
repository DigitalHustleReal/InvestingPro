function buildNav(){
  const groups={};
  NAV.forEach(n=>{if(!groups[n.group])groups[n.group]=[];groups[n.group].push(n);});
  let h='';
  for(const[g,items] of Object.entries(groups)){
    h+=`<div class="sb-sect">${g}</div>`;
    items.forEach(n=>{
      const cnt=n.key?S[n.key].length:null;
      const badge=cnt!==null?`<span class="nav-badge">${cnt}</span>`:'';
      h+=`<div class="nav-item${S.page===n.id?' active':''}" onclick="go('${n.id}')"><em class="nav-ico">${n.ico}</em><span>${n.label}</span>${badge}</div>`;
    });
  }
  document.getElementById('sb-nav').innerHTML=h;
}

function go(page){
  S.page=page;S.selected=[];
  document.getElementById('tb-page').textContent=TITLES[page]||page;
  document.getElementById('tb-section-label').textContent=NAV.find(n=>n.id===page)?.group||'Prism';
  buildNav();
  document.getElementById('page-root').innerHTML=`<div class="page">${renderPage(page)}</div>`;
}

/* ═══════════ AI ═══════════ */
async function ai(prompt,outId,useBtn=false){
  const el=document.getElementById(outId);
  if(!el)return;
  if(!S.apiKey){el.innerHTML='<span style="color:var(--t4);font-style:italic">⚠ Add your Claude API key in Settings → AI Engine to enable generation.</span>';return;}
  el.className='ai-output-area';
  el.innerHTML='<div class="ai-thinking"><div class="thinking-dot"></div><div class="thinking-dot"></div><div class="thinking-dot"></div><span style="margin-left:6px;font-size:11.5px">Generating…</span></div>';
  try{
    const r=await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',
      headers:{'Content-Type':'application/json','x-api-key':S.apiKey,'anthropic-version':'2023-06-01'},
      body:JSON.stringify({model:S.settings.aiModel||'claude-sonnet-4-20250514',max_tokens:1500,system:`You are an expert content writer for ${S.siteName||'the website'}. Write precise, honest, expert content. Avoid filler. Be direct and specific.`,messages:[{role:'user',content:prompt}]})
    });
    const d=await r.json();
    if(d.error)throw new Error(d.error.message);
    const txt=d.content?.[0]?.text||'';
    el.textContent=txt;el.dataset.val=txt;
  }catch(e){el.textContent='Error: '+e.message;}
}

function applyAI(fromId,toId){
  const src=document.getElementById(fromId);
  const dst=document.getElementById(toId);
  if(!src||!dst)return;
  const t=src.dataset.val||src.textContent;
  if(!t||t.includes('Add your Claude'))return;
  if(dst.tagName==='INPUT'||dst.tagName==='TEXTAREA'){dst.value=t;}
  else{dst.innerHTML=t;}
  toast('Applied ✓','success');
}

function buildAIPanel(uid,chips,targetId=''){
