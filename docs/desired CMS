function addField(cid){
  const name=document.getElementById('nf-name')?.value?.trim();
  const type=document.getElementById('nf-type')?.value;
  const req=document.getElementById('nf-req-t')?.classList.contains('on');
  if(!name)return;
  const c=S.collections.find(x=>x.id===cid);
  c.fields.push({n:name,t:type,req,ai:false});
  save('collections');editCollection(cid);
}
function removeField(cid,idx){const c=S.collections.find(x=>x.id===cid);c.fields.splice(idx,1);save('collections');editCollection(cid);}
function toggleAI(cid,idx){const c=S.collections.find(x=>x.id===cid);c.fields[idx].ai=!c.fields[idx].ai;save('collections');editCollection(cid);}
function saveCollection(id){
  const c=S.collections.find(x=>x.id===id);
  c.name=document.getElementById('cn-name')?.value||c.name;
  c.icon=document.getElementById('cn-icon')?.value||c.icon;
  c.description=document.getElementById('cn-desc')?.value||c.description;
  save('collections');toast('Schema saved ✓','success');closeAndRefresh();
}
function newCollection(){
  const id=Date.now();
  S.collections.push({id,name:'New Collection',slug:'new-collection',icon:'📄',description:'My new collection',fields:[{n:'title',t:'text',req:true,ai:true},{n:'content',t:'richtext',ai:true},{n:'status',t:'select',req:true}],count:0,apiEndpoint:'/api/new-collection'});
  save('collections');editCollection(id);
}

