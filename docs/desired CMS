function copyNextSnippet(){
  var snippet='// pages/index.js\nexport async function getStaticProps() {\n  const data = await fetch(\'/data/prism-export.json\').then(r => r.json())\n  return { props: { items: data.items }, revalidate: 3600 }\n}';
  navigator.clipboard.writeText(snippet).then(function(){toast('Code copied ✓','success');});
}
function downloadExport(){
  const d={items:S.content.filter(i=>i.status==='published'),collections:S.collections.map(c=>({name:c.name,slug:c.slug,fields:c.fields.map(f=>f.n)})),meta:{generated:new Date().toISOString(),version:'3.0',site:S.siteName}};
  const a=document.createElement('a');a.href='data:application/json;charset=utf-8,'+encodeURIComponent(JSON.stringify(d,null,2));a.download=`prism-export-${new Date().toISOString().slice(0,10)}.json`;a.click();toast('JSON downloaded ✓','success');
}
async function triggerDeploy(){
  if(!S.settings.vercelHook){toast('No deploy hook configured','error');return;}
  try{await fetch(S.settings.vercelHook,{method:'POST'});toast('Deployment triggered ✓','success');}
  catch(e){toast('Deploy failed: '+e.message,'error');}
}

/* ── TEAM ── */
function pgTeam(){
  const roles=['Admin','Editor','Author','Viewer'];
  const rows=S.team.map(m=>`<tr><td><div class="td-main">${m.name}</div><div class="td-sub">${m.email}</div></td><td><span class="badge ${m.role==='Admin'?'b-re':m.role==='Editor'?'b-vi':m.role==='Author'?'b-cy':'b-dim'}">${m.role}</span></td><td><span class="badge ${m.status==='active'?'b-gr':'b-dim'}">${m.status}</span></td><td><div style="display:flex;gap:4px;opacity:0;transition:opacity .13s" class="row-act"><button class="btn btn-ghost btn-icon-sm">✏️</button><button class="btn btn-ghost btn-icon-sm" onclick="if(m.id!==1)toast('Member removed','success')">🗑</button></div></td></tr>`).join('');
  const perms=[
    {action:'Create content',admin:true,editor:true,author:true,viewer:false},
    {action:'Edit any content',admin:true,editor:true,author:false,viewer:false},
    {action:'Edit own content',admin:true,editor:true,author:true,viewer:false},
    {action:'Publish content',admin:true,editor:true,author:false,viewer:false},
    {action:'Delete content',admin:true,editor:false,author:false,viewer:false},
    {action:'Manage collections',admin:true,editor:false,author:false,viewer:false},
    {action:'Access AI Studio',admin:true,editor:true,author:true,viewer:false},
    {action:'Manage team',admin:true,editor:false,author:false,viewer:false},
    {action:'Configure webhooks',admin:true,editor:false,author:false,viewer:false},
    {action:'View analytics',admin:true,editor:true,author:false,viewer:false},
  ];
  const permRows=perms.map(p=>`<tr><td style="color:var(--t2)">${p.action}</td>${['admin','editor','author','viewer'].map(r=>`<td style="text-align:center">${p[r]?'<span style="color:var(--gr)">✓</span>':'<span style="color:var(--t4)">—</span>'}</td>`).join('')}</tr>`).join('');
  return`
    <div class="page-header">
      <div class="page-eyebrow">Collaboration</div>
      <div class="page-title">Team & Roles</div>
      <div class="page-sub">Manage team members and their permissions. Role-based access control with 4 permission levels.</div>
    </div>
    <div class="panel" style="margin-bottom:18px">
      <div class="panel-hd">
        <div class="panel-title">Team Members (${S.team.length})</div>
        <div class="panel-actions"><button class="btn btn-primary btn-sm" onclick="inviteTeam()">+ Invite Member</button></div>
      </div>
      <table><thead><tr><th>Member</th><th>Role</th><th>Status</th><th></th></tr></thead><tbody>${rows}</tbody></table>
    </div>
    <div class="panel">
      <div class="panel-hd"><div class="panel-title">Permissions Matrix</div></div>
      <table><thead><tr><th>Action</th><th>Admin</th><th>Editor</th><th>Author</th><th>Viewer</th></tr></thead><tbody>${permRows}</tbody></table>
    </div>`;
}
function inviteTeam(){
  modal(`
    <div class="modal-head"><div class="modal-title">Invite Team Member</div><button class="close-btn" onclick="closeModal()">✕</button></div>
    <div class="modal-body">
      <div class="form-row form-2col">
        <div class="field form-span"><label class="label">Email Address</label><input class="input" id="inv-email" type="email" placeholder="colleague@example.com"></div>
        <div class="field"><label class="label">Name</label><input class="input" id="inv-name" placeholder="Full name"></div>
        <div class="field"><label class="label">Role</label><select class="select" id="inv-role"><option>Editor</option><option>Author</option><option>Viewer</option><option>Admin</option></select></div>
      </div>
    </div>
    <div class="modal-foot"><button class="btn btn-ghost" onclick="closeModal()">Cancel</button><button class="btn btn-primary" onclick="saveInvite()">Send Invite</button></div>`,480);
}
function saveInvite(){
  const email=document.getElementById('inv-email')?.value?.trim();
  if(!email){toast('Email required','error');return;}
  S.team.push({id:Date.now(),name:document.getElementById('inv-name')?.value||email,email,role:document.getElementById('inv-role')?.value||'Editor',status:'invited'});
  save('team');toast('Invite sent ✓','success');closeAndRefresh();
}

