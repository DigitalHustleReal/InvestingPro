async function runBulkGen(){
  const lines=(document.getElementById('bg-titles')?.value||'').trim().split('\n').filter(Boolean);
  if(!lines.length){toast('Add at least one title','error');return;}
  document.getElementById('bg-progress').style.display='block';
  const col=document.getElementById('bg-col')?.value||'Articles';
  const st=document.getElementById('bg-st')?.value||'draft';
  const wc=document.getElementById('bg-wc')?.value||1000;
  for(let i=0;i<lines.length;i++){
    const title=lines[i].trim();
    let content='';
    if(S.apiKey){
      try{
        const r=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',
          headers:{'Content-Type':'application/json','x-api-key':S.apiKey,'anthropic-version':'2023-06-01'},
          body:JSON.stringify({model:S.settings.aiModel||'claude-sonnet-4-20250514',max_tokens:1600,
            system:`You are an expert content writer for ${S.siteName||'the website'}. Write specific, data-driven content. No fluff.`,
            messages:[{role:'user',content:`Write a ${wc}-word SEO article titled "${title}". Structure: intro, 3-4 H2 sections, comparison/data table if relevant, 3 FAQs, CTA conclusion. Specific, honest, data-driven.`}]})});
        const d=await r.json();content=d.content?.[0]?.text||'';
      }catch(e){content='[Generation error: '+e.message+']';}
    }
    S.content.unshift({id:Date.now()+i,title,collection:col,status:st,content,wordCount:content.split(/\s+/).filter(Boolean).length,aiScore:content.length>300?Math.round(75+Math.random()*20):0,seoScore:0,author:'AI Bulk',updated:Date.now(),tags:[]});
    const el=document.getElementById('bg-n');if(el)el.textContent=i+1;
  }
  save('content');toast(`${lines.length} articles generated ✓`,'success');closeAndRefresh();
}

