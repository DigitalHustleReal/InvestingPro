<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Prism CMS — AI-Native Content Platform</title>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{
  --c0:#030508;--c1:#080C14;--c2:#0E1420;--c3:#141C2E;--c4:#1A243C;
  --br:#1E2A3E;--br2:#263348;--br3:#2E3D57;
  --t1:#F0F4FF;--t2:#8B9EC4;--t3:#4A5A7A;--t4:#2E3A52;
  --vi:#6C63FF;--vi2:#5A52DD;--vix:rgba(108,99,255,.12);--vib:rgba(108,99,255,.06);
  --gr:#00D084;--grx:rgba(0,208,132,.1);--grd:rgba(0,208,132,.05);
  --am:#FF9F43;--amx:rgba(255,159,67,.1);
  --re:#FF5B5B;--rex:rgba(255,91,91,.1);
  --cy:#22D3EE;--cyx:rgba(34,211,238,.1);
  --pk:#F72585;--pkx:rgba(247,37,133,.1);
  --r6:6px;--r8:8px;--r10:10px;--r12:12px;--r16:16px;
  --sb:240px;--topH:52px;
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;background:var(--c0);color:var(--t1);font-family:'Plus Jakarta Sans',system-ui,sans-serif;font-size:13px;-webkit-font-smoothing:antialiased;overflow:hidden}

/* ── LAYOUT ── */
.shell{display:flex;height:100vh;overflow:hidden}
.sidebar{width:var(--sb);background:var(--c1);border-right:1px solid var(--br);display:flex;flex-direction:column;flex-shrink:0;overflow-y:auto;scrollbar-width:none;transition:width .2s ease}
.sidebar::-webkit-scrollbar{display:none}
.main-area{flex:1;display:flex;flex-direction:column;overflow:hidden;min-width:0}
.topbar{height:var(--topH);background:var(--c1);border-bottom:1px solid var(--br);display:flex;align-items:center;padding:0 20px;gap:12px;flex-shrink:0}
.page-area{flex:1;overflow-y:auto;scrollbar-width:thin;scrollbar-color:var(--br) transparent}
.page-area::-webkit-scrollbar{width:4px}
.page-area::-webkit-scrollbar-thumb{background:var(--br2);border-radius:4px}

/* ── SIDEBAR ── */
.sb-brand{padding:16px;border-bottom:1px solid var(--br);display:flex;align-items:center;gap:10px}
.sb-logo-wrap{width:30px;height:30px;border-radius:8px;background:linear-gradient(135deg,var(--vi) 0%,var(--cy) 100%);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.sb-logo-wrap svg{width:16px;height:16px}
.sb-name{font-size:15px;font-weight:800;letter-spacing:-.03em;color:var(--t1)}
.sb-ver{font-size:9.5px;color:var(--t3);font-family:'Fira Code',monospace;margin-top:1px}
.sb-workspace{margin:10px 12px;background:var(--c2);border:1px solid var(--br);border-radius:var(--r8);padding:9px 11px;cursor:pointer;transition:all .14s;display:flex;align-items:center;gap:8px}
.sb-workspace:hover{border-color:var(--vi);background:var(--vib)}
.ws-dot{width:8px;height:8px;border-radius:50%;background:var(--gr);box-shadow:0 0 6px var(--gr);flex-shrink:0}
.ws-name{font-size:12px;font-weight:600;color:var(--t1);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.ws-caret{color:var(--t3);font-size:10px}
.sb-sect{padding:14px 14px 4px;font-size:8.5px;letter-spacing:.18em;text-transform:uppercase;color:var(--t3);font-family:'Fira Code',monospace}
.nav-item{display:flex;align-items:center;gap:9px;padding:8px 14px;margin:1px 8px;border-radius:var(--r8);cursor:pointer;font-size:12.5px;color:var(--t2);transition:all .13s;user-select:none;position:relative}
.nav-item:hover{background:var(--c2);color:var(--t1)}
.nav-item.active{background:var(--vix);color:var(--vi);font-weight:600}
.nav-item.active::before{content:'';position:absolute;left:0;top:4px;bottom:4px;width:2px;background:var(--vi);border-radius:0 2px 2px 0;left:-8px}
.nav-ico{width:16px;height:16px;flex-shrink:0;opacity:.7;font-style:normal}
.nav-item.active .nav-ico{opacity:1}
.nav-badge{margin-left:auto;background:var(--c3);border:1px solid var(--br);padding:1px 6px;border-radius:10px;font-size:8.5px;color:var(--t3);font-family:'Fira Code',monospace}
.nav-item.active .nav-badge{background:var(--vix);border-color:rgba(108,99,255,.3);color:var(--vi)}
.nav-group-sub{margin-left:24px}
.nav-sub-item{display:flex;align-items:center;gap:8px;padding:6px 10px;margin:1px 0;border-radius:var(--r6);cursor:pointer;font-size:12px;color:var(--t3);transition:all .12s}
.nav-sub-item:hover{color:var(--t1);background:var(--c2)}
.nav-sub-item.active{color:var(--vi)}
.sb-footer{padding:12px;border-top:1px solid var(--br);margin-top:auto}
.ai-status{display:flex;align-items:center;gap:8px;padding:8px 10px;background:var(--c2);border-radius:var(--r8);border:1px solid var(--br);cursor:pointer;transition:all .14s}
.ai-status:hover{border-color:var(--vi)}
.ai-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.ai-dot.on{background:var(--gr);box-shadow:0 0 6px var(--gr);animation:pulse 2s infinite}
.ai-dot.off{background:var(--am)}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
.ai-txt{font-size:11px;color:var(--t2);flex:1}
.ai-txt strong{color:var(--t1);font-weight:600}
.ai-setup-btn{font-size:10px;color:var(--vi);padding:2px 7px;background:var(--vix);border-radius:4px;border:none;cursor:pointer;font-family:inherit;white-space:nowrap}

/* ── TOPBAR ── */
.tb-breadcrumb{display:flex;align-items:center;gap:6px;font-size:12.5px;color:var(--t2);flex:1;min-width:0}
.tb-sep{color:var(--t4)}
.tb-page{font-weight:700;color:var(--t1)}
.tb-actions{display:flex;align-items:center;gap:8px}
.tb-search{display:flex;align-items:center;gap:6px;background:var(--c2);border:1px solid var(--br);border-radius:var(--r8);padding:6px 11px;font-size:12px;color:var(--t2);cursor:text;transition:border-color .14s;min-width:200px}
.tb-search:hover{border-color:var(--br3)}
.tb-search input{background:none;border:none;outline:none;font-family:inherit;font-size:12px;color:var(--t1);flex:1}
.tb-search input::placeholder{color:var(--t3)}

/* ── BUTTONS ── */
.btn{display:inline-flex;align-items:center;gap:6px;padding:7px 14px;border-radius:var(--r8);font-family:'Plus Jakarta Sans',sans-serif;font-size:12px;font-weight:600;cursor:pointer;border:none;transition:all .14s;white-space:nowrap;text-decoration:none}
.btn-primary{background:var(--vi);color:#fff}.btn-primary:hover{background:var(--vi2);transform:translateY(-1px);box-shadow:0 4px 14px rgba(108,99,255,.35)}
.btn-secondary{background:var(--c3);border:1px solid var(--br2);color:var(--t2)}.btn-secondary:hover{border-color:var(--vi);color:var(--vi);background:var(--vib)}
.btn-ghost{background:transparent;border:1px solid var(--br);color:var(--t3)}.btn-ghost:hover{border-color:var(--vi);color:var(--vi)}
.btn-danger{background:var(--rex);border:1px solid rgba(255,91,91,.2);color:var(--re)}.btn-danger:hover{background:rgba(255,91,91,.18)}
.btn-success{background:var(--grx);border:1px solid rgba(0,208,132,.2);color:var(--gr)}.btn-success:hover{background:rgba(0,208,132,.18)}
.btn-sm{padding:5px 10px;font-size:11.5px}
.btn-xs{padding:3px 8px;font-size:10.5px;border-radius:5px}
.btn-icon{width:30px;height:30px;padding:0;justify-content:center;border-radius:var(--r8)}
.btn-icon-sm{width:26px;height:26px;padding:0;justify-content:center;border-radius:6px}

/* ── PAGE ── */
.page{padding:22px 24px;animation:fadeIn .18s ease}
@keyframes fadeIn{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:translateY(0)}}
.page-header{margin-bottom:22px}
.page-eyebrow{font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:var(--vi);margin-bottom:6px;font-family:'Fira Code',monospace;display:flex;align-items:center;gap:6px}
.page-eyebrow::before{content:'';width:16px;height:1px;background:var(--vi)}
.page-title{font-size:22px;font-weight:800;letter-spacing:-.03em;color:var(--t1);margin-bottom:5px}
.page-sub{font-size:13px;color:var(--t2);max-width:580px;line-height:1.65}

/* ── METRIC CARDS ── */
.metrics{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:12px;margin-bottom:24px}
.metric{background:var(--c1);border:1px solid var(--br);border-radius:var(--r12);padding:16px;transition:all .15s;cursor:pointer;position:relative;overflow:hidden}
.metric::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;opacity:0;transition:opacity .15s}
.metric:hover{border-color:var(--br3);transform:translateY(-1px)}
.metric:hover::after{opacity:1}
.metric.vi::after{background:var(--vi)}.metric.gr::after{background:var(--gr)}.metric.am::after{background:var(--am)}.metric.cy::after{background:var(--cy)}.metric.pk::after{background:var(--pk)}
.metric-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px}
.metric-icon{width:32px;height:32px;border-radius:var(--r8);display:flex;align-items:center;justify-content:center;font-size:15px}
.metric-icon.vi{background:var(--vix)}.metric-icon.gr{background:var(--grx)}.metric-icon.am{background:var(--amx)}.metric-icon.cy{background:var(--cyx)}.metric-icon.pk{background:var(--pkx)}
.metric-delta{font-size:10px;font-family:'Fira Code',monospace;padding:2px 7px;border-radius:5px;font-weight:500}
.delta-up{background:var(--grx);color:var(--gr)}.delta-dn{background:var(--rex);color:var(--re)}.delta-nt{background:var(--c3);color:var(--t3)}
.metric-val{font-size:28px;font-weight:800;letter-spacing:-.04em;line-height:1;margin-bottom:4px}
.metric-val.vi{color:var(--vi)}.metric-val.gr{color:var(--gr)}.metric-val.am{color:var(--am)}.metric-val.cy{color:var(--cy)}.metric-val.pk{color:var(--pk)}
.metric-label{font-size:11px;color:var(--t3)}
.metric-bar{height:3px;background:var(--c3);border-radius:2px;margin-top:10px;overflow:hidden}
.metric-fill{height:100%;border-radius:2px;transition:width .8s ease}

/* ── PANELS ── */
.panel{background:var(--c1);border:1px solid var(--br);border-radius:var(--r12);overflow:hidden;margin-bottom:18px}
.panel-hd{padding:12px 16px;border-bottom:1px solid var(--br);display:flex;align-items:center;justify-content:space-between;gap:10px}
.panel-hd-left{display:flex;align-items:center;gap:10px;flex:1;min-width:0}
.panel-title{font-size:13px;font-weight:700;color:var(--t1)}
.panel-sub{font-size:11.5px;color:var(--t3);margin-top:1px}
.panel-actions{display:flex;align-items:center;gap:7px;flex-shrink:0}

/* ── TABLE ── */
.tbl-wrap{overflow-x:auto}
table{width:100%;border-collapse:collapse}
thead th{padding:9px 14px;text-align:left;font-size:9px;letter-spacing:.12em;text-transform:uppercase;color:var(--t3);font-weight:500;background:var(--c2);border-bottom:1px solid var(--br);white-space:nowrap;font-family:'Fira Code',monospace}
thead th:first-child{padding-left:16px}
td{padding:11px 14px;border-bottom:1px solid var(--br);vertical-align:middle;font-size:12.5px}
td:first-child{padding-left:16px}
tbody tr:last-child td{border:none}
tbody tr{transition:background .1s}
tbody tr:hover{background:rgba(255,255,255,.018)}
.td-main{font-weight:600;color:var(--t1)}
.td-sub{font-size:11px;color:var(--t3);margin-top:2px}
.td-mono{font-family:'Fira Code',monospace;font-size:11.5px;color:var(--t2)}
.empty-row{text-align:center;padding:48px 20px}
.empty-ico{font-size:36px;margin-bottom:12px}
.empty-title{font-size:17px;font-weight:700;color:var(--t1);margin-bottom:6px;letter-spacing:-.02em}
.empty-sub{font-size:12.5px;color:var(--t3);max-width:300px;margin:0 auto 18px;line-height:1.65}

/* ── BADGES ── */
.badge{display:inline-flex;align-items:center;gap:4px;padding:3px 8px;border-radius:20px;font-size:10px;font-weight:600;white-space:nowrap}
.badge::before{content:'';width:5px;height:5px;border-radius:50%;flex-shrink:0}
.b-vi{background:var(--vix);color:var(--vi);border:1px solid rgba(108,99,255,.2)}.b-vi::before{background:var(--vi)}
.b-gr{background:var(--grx);color:var(--gr);border:1px solid rgba(0,208,132,.2)}.b-gr::before{background:var(--gr)}
.b-am{background:var(--amx);color:var(--am);border:1px solid rgba(255,159,67,.2)}.b-am::before{background:var(--am)}
.b-re{background:var(--rex);color:var(--re);border:1px solid rgba(255,91,91,.2)}.b-re::before{background:var(--re)}
.b-cy{background:var(--cyx);color:var(--cy);border:1px solid rgba(34,211,238,.2)}.b-cy::before{background:var(--cy)}
.b-dim{background:var(--c3);color:var(--t3);border:1px solid var(--br)}.b-dim::before{background:var(--t3)}
.b-pk{background:var(--pkx);color:var(--pk);border:1px solid rgba(247,37,133,.2)}.b-pk::before{background:var(--pk)}

/* ── SCORE BAR ── */
.score-wrap{display:flex;align-items:center;gap:8px;min-width:100px}
.score-bar{flex:1;height:4px;background:var(--c3);border-radius:2px;overflow:hidden}
.score-fill{height:100%;border-radius:2px;transition:width .6s ease}
.score-num{font-family:'Fira Code',monospace;font-size:10.5px;font-weight:500;width:26px;text-align:right}
.score-hi{color:var(--gr)}.score-md{color:var(--am)}.score-lo{color:var(--re)}

/* ── FORMS ── */
.form-row{display:grid;gap:14px;margin-bottom:14px}
.form-2col{grid-template-columns:1fr 1fr}
.form-3col{grid-template-columns:1fr 1fr 1fr}
.form-span{grid-column:1/-1}
.field{display:flex;flex-direction:column;gap:5px}
.label{font-size:10.5px;font-weight:600;color:var(--t2);letter-spacing:.05em;text-transform:uppercase;font-family:'Fira Code',monospace}
.label-hint{font-weight:400;color:var(--t3);font-size:9.5px;margin-left:6px}
.input,.select,.textarea{padding:9px 11px;background:var(--c2);border:1px solid var(--br);border-radius:var(--r8);font-family:'Plus Jakarta Sans',sans-serif;font-size:13px;color:var(--t1);outline:none;transition:border-color .14s,box-shadow .14s;width:100%}
.input::placeholder,.textarea::placeholder{color:var(--t3)}
.input:focus,.select:focus,.textarea:focus{border-color:var(--vi);box-shadow:0 0 0 3px rgba(108,99,255,.1)}
.textarea{resize:vertical;min-height:90px;line-height:1.7}
.select{cursor:pointer}
.input-group{display:flex;gap:0}
.input-group .input{border-radius:var(--r8) 0 0 var(--r8)}
.input-group .btn{border-radius:0 var(--r8) var(--r8) 0}
.char-count{font-size:10px;color:var(--t3);text-align:right;font-family:'Fira Code',monospace}

/* ── TOGGLE ── */
.toggle{display:flex;align-items:center;gap:8px;cursor:pointer}
.toggle-track{width:36px;height:20px;background:var(--c3);border-radius:10px;position:relative;transition:background .2s;flex-shrink:0;border:1px solid var(--br)}
.toggle-track.on{background:var(--vi);border-color:var(--vi)}
.toggle-thumb{position:absolute;width:14px;height:14px;background:#fff;border-radius:50%;top:2px;left:2px;transition:transform .2s;box-shadow:0 1px 3px rgba(0,0,0,.3)}
.toggle-track.on .toggle-thumb{transform:translateX(16px)}
.toggle-label{font-size:12.5px;color:var(--t2)}

/* ── MODAL ── */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.7);display:flex;align-items:center;justify-content:center;z-index:500;backdrop-filter:blur(6px);padding:20px;animation:fadeIn .15s ease}
.modal{background:var(--c1);border:1px solid var(--br2);border-radius:var(--r16);width:100%;max-height:92vh;overflow:hidden;display:flex;flex-direction:column;box-shadow:0 24px 80px rgba(0,0,0,.7)}
.modal-head{padding:20px 22px 16px;border-bottom:1px solid var(--br);display:flex;align-items:center;justify-content:space-between;flex-shrink:0}
.modal-title{font-size:17px;font-weight:800;letter-spacing:-.03em;color:var(--t1)}
.modal-title-sub{font-size:11.5px;color:var(--t3);margin-top:2px}
.modal-body{padding:20px 22px;overflow-y:auto;flex:1;scrollbar-width:thin;scrollbar-color:var(--br) transparent}
.modal-foot{padding:14px 22px;border-top:1px solid var(--br);display:flex;align-items:center;justify-content:flex-end;gap:8px;flex-shrink:0;background:var(--c2)}
.modal-foot-left{margin-right:auto;display:flex;gap:8px}
.close-btn{width:28px;height:28px;background:var(--c3);border:none;border-radius:7px;display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--t3);font-size:13px;transition:all .13s}
.close-btn:hover{background:var(--br2);color:var(--t1)}

/* ── TABS ── */
.tabs{display:flex;gap:2px;background:var(--c2);border-radius:var(--r10);padding:3px;margin-bottom:18px}
.tab{padding:7px 14px;border-radius:var(--r8);font-size:12.5px;font-weight:600;cursor:pointer;color:var(--t3);transition:all .14s;user-select:none}
.tab:hover{color:var(--t2)}
.tab.active{background:var(--c1);color:var(--t1);box-shadow:0 1px 4px rgba(0,0,0,.2)}

/* ── AI PANEL ── */
.ai-panel{background:linear-gradient(180deg,var(--c0) 0%,rgba(108,99,255,.04) 100%);border:1px solid var(--br2);border-radius:var(--r12);overflow:hidden;margin-bottom:18px}
.ai-panel-header{padding:12px 14px;border-bottom:1px solid var(--br);display:flex;align-items:center;justify-content:space-between}
.ai-panel-brand{display:flex;align-items:center;gap:7px}
.ai-gem{width:22px;height:22px;border-radius:6px;background:linear-gradient(135deg,var(--vi),var(--cy));display:flex;align-items:center;justify-content:center;font-size:11px;animation:gemGlow 3s infinite}
@keyframes gemGlow{0%,100%{box-shadow:0 0 8px rgba(108,99,255,.3)}50%{box-shadow:0 0 16px rgba(108,99,255,.6)}}
.ai-panel-label{font-size:10.5px;font-weight:700;color:var(--vi);letter-spacing:.04em}
.ai-chips-row{padding:10px 14px;display:flex;flex-wrap:wrap;gap:6px;border-bottom:1px solid var(--br)}
.chip{padding:5px 12px;background:var(--c2);border:1px solid var(--br2);border-radius:20px;font-size:11.5px;color:var(--t2);cursor:pointer;transition:all .13s;font-family:'Plus Jakarta Sans',sans-serif}
.chip:hover{background:var(--vix);border-color:rgba(108,99,255,.3);color:var(--vi)}
.chip:active{transform:scale(.97)}
.ai-output-area{min-height:80px;padding:12px 14px;font-size:12.5px;color:var(--t2);line-height:1.75;white-space:pre-wrap;max-height:220px;overflow-y:auto}
.ai-output-area.empty{color:var(--t4);font-style:italic;font-size:12px}
.ai-thinking{display:flex;align-items:center;gap:6px;color:var(--t3);font-size:12px}
.thinking-dot{width:4px;height:4px;border-radius:50%;background:var(--vi);animation:tpulse 1.4s infinite}
.thinking-dot:nth-child(2){animation-delay:.2s}.thinking-dot:nth-child(3){animation-delay:.4s}
@keyframes tpulse{0%,80%,100%{transform:scale(.6);opacity:.4}40%{transform:scale(1);opacity:1}}
.ai-input-row{padding:10px 14px;border-top:1px solid var(--br);display:flex;gap:8px;background:var(--c2)}
.ai-custom{flex:1;padding:8px 11px;background:var(--c1);border:1px solid var(--br);border-radius:var(--r8);font-family:'Plus Jakarta Sans',sans-serif;font-size:12.5px;color:var(--t1);outline:none;transition:border-color .14s}
.ai-custom::placeholder{color:var(--t4)}
.ai-custom:focus{border-color:var(--vi)}
.ai-use-btn{padding:4px 10px;background:var(--vix);border:none;border-radius:5px;color:var(--vi);font-size:10.5px;cursor:pointer;font-family:inherit;font-weight:600;transition:all .13s;white-space:nowrap}
.ai-use-btn:hover{background:rgba(108,99,255,.2)}

/* ── NOTICE BOXES ── */
.notice{padding:11px 14px;border-radius:var(--r8);font-size:12px;line-height:1.65;margin-bottom:16px;display:flex;gap:10px;align-items:flex-start}
.notice-icon{font-size:14px;flex-shrink:0;margin-top:1px}
.notice-text{flex:1}
.notice.info{background:var(--cyx);border:1px solid rgba(34,211,238,.2);color:#90E0EF}
.notice.warn{background:var(--amx);border:1px solid rgba(255,159,67,.2);color:#FFC97E}
.notice.success{background:var(--grx);border:1px solid rgba(0,208,132,.2);color:#6EEDC3}
.notice.danger{background:var(--rex);border:1px solid rgba(255,91,91,.2);color:#FF9999}

/* ── SCHEMA BUILDER ── */
.field-list{display:flex;flex-direction:column;gap:8px;margin-bottom:14px}
