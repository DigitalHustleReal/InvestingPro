  ['tab-content','tab-seo','tab-meta'].forEach(t=>{const el=document.getElementById(t);if(el)el.style.display=t===tabId?'block':'none';});
}
function updateContent(id){
  const i=S.content.find(x=>x.id===id);if(!i)return;
  i.title=document.getElementById('ed-title')?.value||i.title;
  i.status=document.getElementById('ed-status')?.value||i.status;
  i.category=document.getElementById('ed-cat')?.value||i.category;
  i.keyword=document.getElementById('ed-kw')?.value||i.keyword;
  i.metaTitle=document.getElementById('ed-seo-title')?.value||i.metaTitle;
  i.metaDescription=document.getElementById('ed-meta')?.value||i.metaDescription;
  i.slug=document.getElementById('ed-slug')?.value||i.slug;
  i.author=document.getElementById('ed-author')?.value||i.author;
  i.tags=(document.getElementById('ed-tags')?.value||'').split(',').map(t=>t.trim()).filter(Boolean);
  i.publishDate=document.getElementById('ed-pubdate')?.value||i.publishDate;
  i.collection=document.getElementById('ed-col')?.value||i.collection;
  const c=document.getElementById('ed-content')?.value||'';
  i.content=c;i.wordCount=c.split(/\s+/).filter(Boolean).length;
  i.aiScore=c.length>300?Math.min(98,Math.round(75+Math.random()*20)):i.aiScore;
  i.seoScore=i.metaDescription?.length>50&&i.metaTitle?.length>10?Math.min(96,Math.round(72+Math.random()*22)):i.seoScore;
  i.updated=Date.now();
  save('content');toast('Saved ✓','success');closeAndRefresh();
}
function togglePublish(id){const i=S.content.find(x=>x.id===id);if(!i)return;i.status=i.status==='published'?'draft':'published';i.updated=Date.now();save('content');}
function dupContent(id){const src=S.content.find(i=>i.id===id);if(!src)return;S.content.unshift({...src,id:Date.now(),title:src.title+' (Copy)',status:'draft',updated:Date.now()});save('content');toast('Duplicated ✓','success');go(S.page);}
function delContent(id){if(!confirm('Delete this item?'))return;S.content=S.content.filter(i=>i.id!==id);save('content');toast('Deleted','success');closeAndRefresh();}
function toggleSel(id,on){if(on)S.selected.push(id);else S.selected=S.selected.filter(x=>x!==id);}

