function saveAPIKey(){
  const k=document.getElementById('s-key')?.value?.trim();
  S.apiKey=k;DB.set('apiKey',k);
  S.settings.aiModel=document.getElementById('s-model')?.value||S.settings.aiModel;
  save('settings');
  document.getElementById('ai-dot').className='ai-dot'+(k?' on':' off');
  document.getElementById('ai-txt-sub').textContent=k?'claude-sonnet-4-20250514':'Not connected';
  document.getElementById('ai-setup-btn').textContent=k?'Active':'Configure';
  toast('AI Engine connected ✓','success');
  renderPage('settings');document.getElementById('page-root').innerHTML=`<div class="page">${pgSettings()}</div>`;
}
function saveSetting(k,id,label){const v=document.getElementById(id)?.value?.trim();S.settings[k]=v;save('settings');toast(label+' saved ✓','success');}
function saveWorkspace(){S.siteName=document.getElementById('s-site')?.value||S.siteName;DB.set('siteName',S.siteName);S.settings.siteDomain=document.getElementById('s-domain')?.value||'';S.settings.defaultLocale=document.getElementById('s-locale')?.value||'en';save('settings');document.getElementById('ws-name').textContent=S.siteName;toast('Workspace saved ✓','success');}
function saveSupabase(){S.settings.supabaseUrl=document.getElementById('s-sburl')?.value||'';S.settings.supabaseKey=document.getElementById('s-sbkey')?.value||'';save('settings');toast('Supabase configured ✓','success');}
function exportBackup(){const d={content:S.content,collections:S.collections,keywords:S.keywords,pipeline:S.pipeline,media:S.media,team:S.team};const a=document.createElement('a');a.href='data:application/json;charset=utf-8,'+encodeURIComponent(JSON.stringify(d,null,2));a.download='prism-backup-'+new Date().toISOString().slice(0,10)+'.json';a.click();toast('Backup downloaded ✓','success');}
function clearAll(){if(!confirm('Delete ALL workspace data? This cannot be undone.'))return;['content','collections','keywords','pipeline','media','team'].forEach(k=>{S[k]=k==='collections'?defaultCollections():k==='team'?[{id:1,name:'You (Admin)',email:'admin@example.com',role:'Admin',status:'active'}]:[];save(k);});toast('Data cleared','success');go('dashboard');}

/* ═══════════ INIT ═══════════ */
