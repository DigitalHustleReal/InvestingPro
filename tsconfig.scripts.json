{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2020",
    "jsx": "react",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "server-only": ["./scripts/mocks/server-only.js"],
      "@/*": ["./*"]
    }
  },
  "include": ["scripts/**/*", "lib/**/*", "types/**/*"],
  "exclude": ["node_modules"]
}
