# ==========================================
# InvestingPro - Production Environment Variables
# ==========================================
# Copy this file and fill in all values before deployment
# NEVER commit .env files with real secrets to version control

# ==========================================
# 1. SUPABASE (REQUIRED)
# ==========================================
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ==========================================
# 2. BASE URL & DOMAIN (REQUIRED)
# ==========================================
NEXT_PUBLIC_BASE_URL=https://investingpro.in

# ==========================================
# 3. AI CONTENT GENERATION (REQUIRED)
# ==========================================
# Primary AI provider - Required for CMS
OPENAI_API_KEY=sk-proj-...

# Fallback AI providers (Optional but recommended)
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_GEMINI_API_KEY=AIza...
GROQ_API_KEY=gsk_...
MISTRAL_API_KEY=...

# ==========================================
# 4. IMAGE SERVICES (REQUIRED)
# ==========================================
# Cloudinary for image storage and optimization
# Get from: https://console.cloudinary.com/
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Stock photo APIs (Optional)
UNSPLASH_ACCESS_KEY=...
PEXELS_API_KEY=...

# ==========================================
# 5. PAYMENTS (OPTIONAL)
# ==========================================
# Stripe for subscriptions and payments
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ==========================================
# 6. EMAIL SERVICE (OPTIONAL)
# ==========================================
# Resend for transactional emails
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...

# ==========================================
# 7. SEO & ANALYTICS (OPTIONAL)
# ==========================================
# SERP API for keyword research
SERPAPI_API_KEY=...

# Google Trends for trending topics
# (No API key needed - uses google-trends-api package)

# ==========================================
# 8. MONITORING & ERROR TRACKING (RECOMMENDED)
# ==========================================
# Sentry for error tracking
# Get from: https://sentry.io/settings/projects/
SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# ==========================================
# 9. RATE LIMITING (OPTIONAL)
# ==========================================
# Upstash Redis for rate limiting
# Get from: https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# ==========================================
# 10. ANALYTICS (OPTIONAL)
# ==========================================
# PostHog for product analytics
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ==========================================
# 11. SOCIAL MEDIA AUTOMATION (OPTIONAL)
# ==========================================
# For auto-posting generated content
# TWITTER_API_KEY=...
# TWITTER_API_SECRET=...
# TWITTER_ACCESS_TOKEN=...
# TWITTER_ACCESS_SECRET=...

# LINKEDIN_CLIENT_ID=...
# LINKEDIN_CLIENT_SECRET=...

# ==========================================
# 12. CRON JOB AUTHENTICATION (OPTIONAL)
# ==========================================
# Secret token for authenticating cron job requests
# Generate a secure random string (e.g., using: openssl rand -hex 32)
CRON_SECRET=your_secure_random_string_here

# ==========================================
# ⚠️ NEVER SET THESE IN PRODUCTION ⚠️
# ==========================================
# These are for local development ONLY
# ADMIN_BYPASS_KEY=  # DO NOT SET IN PRODUCTION

# ==========================================
# DEPLOYMENT CHECKLIST
# ==========================================
# Before deploying, verify:
# 
# [x] All REQUIRED variables are set
# [x] All API keys are valid and have correct permissions
# [x] NEXT_PUBLIC_BASE_URL matches your production domain
# [x] ADMIN_BYPASS_KEY is NOT set
# [x] Supabase RLS policies are enabled
# [x] Database migrations are applied
# [x] SSL certificate is configured
# [x] Environment variables are set in hosting platform
# [x] Test deployment in staging environment first
